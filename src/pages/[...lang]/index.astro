---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MainContent from "../../layouts/MainContent.astro";
import {
  useTranslations,
  getLocaleStaticPaths,
  getLocalizedPath,
  slugOf,
  isUpcoming,
  type Locale,
} from "../../i18n/utils";
import { getCollection } from "astro:content";
import {
  debutEvent,
  publishedPosts,
  sortByDate,
  thumbnailUrl,
} from "../../content/utils";
import Portrait from "../../assets/portrait-theo-gianella-hero.webp";

export const getStaticPaths = getLocaleStaticPaths;

const lang: Locale = (Astro.params.lang as Locale | undefined) ?? "en";
const t = useTranslations(lang);

const posts = publishedPosts(
  await getCollection("blog", ({ id }) => id.startsWith(`${lang}/`)),
).slice(0, 3);

const talks = (
  await getCollection(
    "talks",
    ({ id, data }) => id.startsWith(`${lang}/`) && data.events.length > 0,
  )
)
  .sort((a, b) => {
    const aMin = Math.min(...a.data.events.map((e) => e.date.valueOf()));
    const bMin = Math.min(...b.data.events.map((e) => e.date.valueOf()));
    return bMin - aMin;
  })
  .slice(0, 3);

const recentPhotos = sortByDate(
  await getCollection("gallery", ({ id }) => id.startsWith(`${lang}/`)),
).slice(0, 4);

const dateFormatter = new Intl.DateTimeFormat(lang, { dateStyle: "medium" });
---

<BaseLayout lang={lang} description={t.seo.description} canonicalPath="/">
  <section class="hero">
    <h1 class="hero__name">{t.seo.siteName}</h1>
    <img
      src={Portrait.src}
      alt=""
      role="presentation"
      class="hero__avatar"
      width="3813"
      height="1870"
    />
    <p class="hero__tagline" data-vt-name="hero-tagline">{t.home.tagline}</p>
    <button class="hero__scroll-hint" aria-label={t.home.scrollToBio}>↓</button>
  </section>

  <section id="bio" class="bio">
    {t.home.bio.map((p) => <p>{p}</p>)}
  </section>

  <MainContent>
    <section class="section">
      <header class="section__header">
        <h2 class="section__title">{t.home.sections.blog}</h2>
        <a
          href={getLocalizedPath("/blog", lang)}
          class="section__see-all"
          aria-label={t.home.seeAllBlog}
        >
          {t.home.seeAll}<span aria-hidden="true"> →</span>
        </a>
      </header>
      <ul class="card-grid">
        {
          posts.map((post) => (
            <li>
              <a
                href={getLocalizedPath(`/blog/${slugOf(post.id, lang)}`, lang)}
                class="card"
              >
                <time
                  class="card__date"
                  datetime={post.data.pubDate.toISOString()}
                >
                  {dateFormatter.format(post.data.pubDate)}
                </time>
                <h3 class="card__title">{post.data.title}</h3>
                <p class="card__desc">{post.data.description}</p>
              </a>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="section">
      <header class="section__header">
        <h2 class="section__title">{t.home.sections.talks}</h2>
        <a
          href={getLocalizedPath("/talks", lang)}
          class="section__see-all"
          aria-label={t.home.seeAllTalks}
        >
          {t.home.seeAll}<span aria-hidden="true"> →</span>
        </a>
      </header>
      <ul class="card-grid">
        {
          talks.map((talk) => {
            // Query above guarantees events.length > 0
            const debut = debutEvent(talk.data.events)!;
            const upcoming = isUpcoming(talk.data.events);
            return (
              <li>
                <a
                  href={getLocalizedPath(
                    `/talks/${slugOf(talk.id, lang)}`,
                    lang,
                  )}
                  class="card"
                >
                  <div class="card__meta">
                    <time
                      class="card__date"
                      datetime={debut.date.toISOString()}
                    >
                      {dateFormatter.format(debut.date)}
                    </time>
                    {upcoming && (
                      <span class="upcoming-pill">{t.talks.upcoming}</span>
                    )}
                  </div>
                  <h3 class="card__title">{talk.data.title}</h3>
                  <p class="card__desc">
                    {debut.name} — {debut.location}
                  </p>
                </a>
              </li>
            );
          })
        }
      </ul>
    </section>

    <section class="section">
      <header class="section__header">
        <h2 class="section__title">{t.home.sections.gallery}</h2>
        <a
          href={getLocalizedPath("/blue-screens", lang)}
          class="section__see-all"
          aria-label={t.home.seeAllGallery}
        >
          {t.home.seeAll}<span aria-hidden="true"> →</span>
        </a>
      </header>
      <ul class="gallery-grid">
        {
          recentPhotos.map((photo) => (
            <li>
              <a
                href={getLocalizedPath(
                  `/blue-screens/${slugOf(photo.id, lang)}`,
                  lang,
                )}
                class="gallery-card"
              >
                <img
                  src={thumbnailUrl(photo.data.src)}
                  alt={photo.data.alt}
                  width={400}
                  height={300}
                  class="gallery-card__img"
                  loading="lazy"
                  decoding="async"
                />
                {photo.data.location && (
                  <div class="gallery-card__caption">
                    <span class="gallery-card__title">
                      {photo.data.location}
                    </span>
                  </div>
                )}
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </MainContent>
</BaseLayout>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    margin-block: 3dvh;
    margin-inline: auto;
    max-inline-size: max(30rem, 95vw);
    min-block-size: calc(92dvh - var(--nav-height));
    padding-inline: var(--page-padding);
  }

  .hero__name {
    width: min-content;
    /* stylelint-disable-next-line defensive-css/no-unsafe-clamp-font-size */
    font-size: clamp(3rem, min(18vw, hypot(10vw, 10dvh)), 14rem);
    line-height: 0.8;
    margin-block: auto var(--size-5);
    margin-inline: 0;
  }

  .hero__avatar {
    max-width: 100%;
    margin-block-end: var(--size-6);
    object-fit: cover;
  }

  .hero__tagline {
    z-index: var(--layer-2);
    width: min-content;
    margin: 0;
    color: var(--text-2);
    font-family: var(--font-transitional);
    /* stylelint-disable-next-line defensive-css/no-unsafe-clamp-font-size */
    font-size: clamp(2.5rem, 12vw, 6rem);
    line-height: 0.9;
    padding-block-end: 0.2em;
    view-transition-class: text-transition;
  }

  .hero__scroll-hint {
    display: block;
    padding: 0;
    border: none;
    background: none;
    color: var(--text-2);
    cursor: pointer;
    font-family: var(--font-transitional);
    /* stylelint-disable-next-line defensive-css/no-unsafe-clamp-font-size */
    font-size: clamp(4rem, 14vw, 8rem);
    line-height: 1;
    margin-block-start: var(--size-4);
    max-block-size: fit-content;
    max-inline-size: fit-content;
    text-align: end;
  }

  @media (width >= 48rem) {
    .hero {
      display: grid;
      grid-template-columns: [left-start] min-content [left-end right-start] 1fr [right-end];
      grid-template-rows: [name-top] auto [name-bottom image-top] 1fr [image-bottom tagline-top] auto [tagline-bottom];
      padding-block: var(--size-5);
      padding-inline: var(--page-padding);
    }

    .hero__name {
      grid-area: 1 / 1;
      margin-block: 0;
    }

    .hero__avatar {
      position: relative;
      left: var(--size-2);
      width: calc(100% - var(--size-2));
      align-self: start;
      border-radius: var(--radius-1);
      box-shadow: var(--shadow-1);
      grid-area: 2 / 1;
      margin-block: var(--size-5) 0;
    }

    .hero__tagline {
      width: min-content;
      /* stylelint-disable-next-line defensive-css/no-unsafe-clamp-font-size */
      font-size: clamp(3rem, 10dvmin, 12rem);
      grid-column: left-start / right-end;
      grid-row: image-top / tagline-bottom;
      place-self: end end;
      text-align: end;
      view-transition-class: text-transition-right;
    }

    .hero__scroll-hint {
      align-self: end;
      /* stylelint-disable-next-line defensive-css/no-unsafe-clamp-font-size */
      font-size: clamp(3rem, 10dvmin, 10rem);
      grid-area: 3 / 1;
      margin-block-start: 0;
      text-align: start;
    }
  }

  /* ── Bio (wider than --layout-width) ───────────────── */
  .bio {
    position: relative;
    inline-size: min(90vw, 100%, 100rem);
    margin-inline: auto;
    padding-block-start: var(--size-3);
    padding-inline: var(--page-padding);

    p {
      font-weight: var(--font-weight-5);

      @media (width >= 48rem) {
        font-size: clamp(1rem, 3vw, 1.75rem);
        max-inline-size: 75%;

        &:nth-child(even) {
          margin-block-start: var(--size-9);
          margin-inline-start: auto;
          text-align: end;
        }
      }
    }
  }

  /* Separator: hero | bio — sits on bio because bio is the narrower */
  .bio::before {
    position: absolute;
    border-block-start: var(--border-size-1) solid var(--border);
    content: "";
    inset-block-start: 0;
    inset-inline: var(--page-padding);
  }

  /* ── Sections ──────────────────────────────────────── */
  .section {
    border-block-end: var(--border-size-1) solid var(--border);
    margin-block-end: var(--size-8);
    padding-block-end: var(--size-8);

    &:last-child {
      border-block-end: none;
      margin-block-end: 0;
      padding-block-end: 0;
    }
  }

  /* Separator: bio | main content — sits on first section because MainContent is the narrower */
  .section:first-child {
    position: relative;
    padding-block-start: var(--size-8);
  }

  .section:first-child::before {
    position: absolute;
    border-block-start: var(--border-size-1) solid var(--border);
    content: "";
    inset-block-start: 0;
    inset-inline: 0;
  }

  .section__header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--size-3);
    margin-block-end: var(--size-4);
  }

  .section__title {
    margin: 0;
    font-size: var(--font-size-4);
  }

  .section__see-all {
    color: var(--text-2);
    font-size: var(--font-size-1);
    text-decoration: none;
    transition: color 0.15s;
    white-space: nowrap;

    @media (hover: hover) {
      &:hover {
        color: var(--color-brand);
      }
    }
  }

  /* ── Content cards ─────────────────────────────────── */
  .card-grid {
    display: grid;
    gap: var(--size-3);
    grid-template-columns: repeat(
      auto-fill,
      [card-start] minmax(min(100%, 260px), 1fr) [card-end]
    );
  }

  .card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: var(--size-3);
    border-radius: var(--radius-2);
    background: var(--surface-2);
    block-size: 100%;
    box-shadow: var(--shadow-3);
    color: inherit;
    gap: 0.375rem;
    text-decoration: none;
    transition: border-color 0.15s;
  }

  .card__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--size-2);
  }

  .card__date {
    color: var(--text-2);
    font-size: var(--font-size-0);
  }

  .card__title {
    margin: 0;
    color: var(--text-1);
    font-size: var(--font-size-2);
    font-weight: var(--font-weight-6);
  }

  .card__desc {
    display: -webkit-box;
    overflow: hidden;
    margin: 0;
    -webkit-box-orient: vertical;
    color: var(--text-2);
    font-size: var(--font-size-1);
    -webkit-line-clamp: 3;
  }

  /* ── Gallery grid ──────────────────────────────────── */
  .gallery-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(
      auto-fill,
      [gallery-start] minmax(min(40dvw, 200px), 1fr) [gallery-end]
    );
  }

  .gallery-card {
    display: block;
    overflow: hidden;
    border-radius: var(--radius-2);
    box-shadow: var(--shadow-3);
    color: var(--text-1);
    text-decoration: none;
  }

  .gallery-card__img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  .gallery-card__caption {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: space-between;
    padding: 0.625rem 0.75rem;
    font-size: var(--font-size-1);
    gap: var(--size-2);
  }

  .gallery-card__title {
    color: var(--text-1);
    font-weight: var(--font-weight-6);
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const hint =
      document.querySelector<HTMLButtonElement>(".hero__scroll-hint");
    const bio = document.getElementById("bio");
    hint?.addEventListener("click", () => {
      if (!bio) return;
      const nav = document.querySelector("nav");
      const navHeight = nav?.offsetHeight ?? 0;
      const top = bio.getBoundingClientRect().top + window.scrollY - navHeight;
      window.scrollTo({ top, behavior: "smooth" });
    });
  });
</script>
