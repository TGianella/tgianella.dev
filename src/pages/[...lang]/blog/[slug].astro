---
import { getImage } from "astro:assets";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import MainContent from "../../../layouts/MainContent.astro";
import PersonCard from "../../../components/PersonCard.astro";
import TableOfContents from "../../../components/TableOfContents.astro";
import {
  useTranslations,
  getDateFormatter,
  getLocalizedPath,
  locales,
  type Locale,
} from "../../../i18n/utils";
import { readingTime } from "../../../content/utils";
import Icon from "../../../components/Icon.astro";
import Lightbox from "../../../components/Lightbox.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.flatMap((post) => {
    const [contentLang, ...slugParts] = post.id.split("/");
    if (!locales.includes(contentLang as Locale)) return [];
    // Default locale uses `undefined` so the [...lang] segment collapses.
    const lang = contentLang === "en" ? undefined : contentLang;
    return [
      {
        params: { lang, slug: slugParts.join("/") },
        props: { post },
      },
    ];
  });
}

const lang: Locale = (Astro.params.lang as Locale | undefined) ?? "en";
const { slug } = Astro.params as { slug: string };
const { post } = Astro.props;
const t = useTranslations(lang);
const { Content, headings } = await render(post);
const hasSidebar =
  post.data.coAuthors.length > 0 ||
  headings.some((h) => h.depth === 2 || h.depth === 3);

const dateFormatter = getDateFormatter(lang);
const ogImage = post.data.thumbnail
  ? (await getImage({ src: post.data.thumbnail })).src
  : undefined;
const minutes = readingTime(post.body);
---

<BaseLayout
  lang={lang}
  title={post.data.title}
  description={post.data.description}
  canonicalPath={`/blog/${slug}`}
  canonicalUrl={post.data.firstPublishedIn?.url}
  ogImage={ogImage}
>
  <MainContent>
    <article
      data-copy-link={t.prose.copyLink}
      data-link-copied={t.prose.linkCopied}
    >
      <a href={getLocalizedPath("/blog", lang)} class="back-link"
        >{t.blog.backToList}</a
      >

      <header class="post-header">
        <div class="post-header__meta">
          <span class="icon-row">
            <Icon name="calendar" />
            <time datetime={post.data.pubDate.toISOString()}
              >{dateFormatter.format(post.data.pubDate)}</time
            >
          </span>
          <span class="icon-row">
            <Icon name="clock" />
            {t.blog.readingTime(minutes)}
          </span>
        </div>

        <h1 class="post-header__title">{post.data.title}</h1>
        <p class="post-header__desc">{post.data.description}</p>

        {
          post.data.tags.length > 0 && (
            <ul class="tag-list" aria-label={t.blog.tags}>
              {post.data.tags.map((tag) => (
                <li class="tag">{tag}</li>
              ))}
            </ul>
          )
        }

        {
          post.data.updatedDate && (
            <p class="post-header__updated">
              {t.blog.updatedOn} {dateFormatter.format(post.data.updatedDate)}
            </p>
          )
        }
      </header>

      <div class="post-body">
        {
          hasSidebar && (
            <aside class="post-sidebar">
              {post.data.coAuthors.length > 0 && (
                <div class="coauthors-sidebar">
                  <p class="coauthors-sidebar__label">{t.blog.writtenWith}</p>
                  <div class="coauthors-sidebar__list">
                    {post.data.coAuthors.map((a) => (
                      <PersonCard
                        name={a.name}
                        picture={a.picture}
                        url={a.url}
                      />
                    ))}
                  </div>
                </div>
              )}
              <TableOfContents
                headings={headings}
                label={t.blog.tableOfContents}
              />
            </aside>
          )
        }

        <div class="prose">
          {
            post.data.firstPublishedIn && (
              <p class="origin-notice">
                <Icon name="info" />
                <span>
                  {t.blog.firstPublishedIn}{" "}
                  {post.data.firstPublishedIn.url ? (
                    <a
                      href={post.data.firstPublishedIn.url}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {post.data.firstPublishedIn.name}
                    </a>
                  ) : (
                    post.data.firstPublishedIn.name
                  )}
                </span>
              </p>
            )
          }
          <Content />
        </div>
      </div>
    </article>
    <Lightbox
      labelDialog={t.a11y.imagePreview}
      labelClose={t.a11y.close}
      labelZoom={t.a11y.imageZoom}
      labelPrev={t.a11y.prevImage}
      labelNext={t.a11y.nextImage}
      navigate={true}
    />
  </MainContent>
</BaseLayout>

<script>
  import "../../../scripts/heading-anchors";
  import "../../../scripts/blog-scroll";
  import "../../../scripts/toc-highlight";
</script>

<style>
  article {
    container-type: inline-size;
    overflow-clip-margin: 10px;
    overflow-x: clip;
  }

  .back-link {
    display: inline-block;
    margin-block-end: var(--size-5);
  }

  .post-header {
    border-block-end: var(--border-size-1) solid var(--border);
    margin-block-end: var(--size-5);
    padding-block-end: var(--size-5);
  }

  .post-header__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    color: var(--text-2);
    font-size: var(--font-size-1);
    gap: 0.9em;
    margin-block-end: 0.75rem;
  }

  /* .icon-row icon layout is provided by the global .icon-row class */

  .post-header__title {
    margin: 0 0 0.75rem;
    font-size: var(--font-size-article-title);
    line-height: 1.1;
  }

  .post-header__desc {
    margin: 0 0 0.875rem;
    color: var(--text-2);
    font-size: var(--font-size-2);
    max-inline-size: 55ch;
  }

  .post-header__updated {
    margin: 0.75rem 0 0;
    color: var(--text-2);
    font-size: var(--font-size-0);
    font-style: italic;
  }

  .post-body {
    display: grid;
    gap: var(--size-4) var(--size-8);
    grid-template-columns: [content-start] 1fr [content-end];
  }

  .post-sidebar {
    min-inline-size: 0;
  }

  @media (width >= 48rem) {
    .post-body {
      grid-template-columns: [content-start] 1fr [content-end aside-start] 14rem [aside-end];
    }

    .prose {
      align-self: start;
      order: -1;
    }

    .post-sidebar {
      display: flex;
      flex-direction: column;
      gap: var(--size-5);
    }
  }

  .coauthors-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--size-3);
  }

  .coauthors-sidebar__list {
    display: flex;
    flex-flow: row wrap;
    gap: var(--size-3);
  }

  @media (width >= 48rem) {
    .coauthors-sidebar__list {
      flex-direction: column;

      & :global(.person-card) {
        width: 100%;
      }
    }
  }

  .coauthors-sidebar__label {
    margin: 0;
    color: var(--text-2);
    font-size: var(--font-size-1);
    font-weight: var(--font-weight-6);
  }

  .origin-notice {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    padding: var(--size-3) var(--size-4);
    border-radius: var(--radius-2);
    margin: 0;
    background: var(--surface-2);
    color: var(--text-2);
    font-size: var(--font-size-1);
    gap: var(--size-4);

    & :global(svg) {
      flex-shrink: 0;
    }
  }
</style>
