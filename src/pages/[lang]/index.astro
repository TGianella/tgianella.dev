---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations, locales, type Locale } from '../../i18n/utils';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return locales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);

const posts = (await getCollection('blog', ({ id }) => id.startsWith(`${lang}/`)))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const talks = (await getCollection('talks', ({ id }) => id.startsWith(`${lang}/`)))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const albums = (await getCollection('gallery', ({ id }) => id.startsWith(`${lang}/`)))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const dateFormatter = new Intl.DateTimeFormat(lang, { dateStyle: 'medium' });
const slugOf = (id: string) => id.replace(`${lang}/`, '');
---

<BaseLayout lang={lang} title={lang === 'en' ? 'Home' : 'Accueil'} description={t.home.tagline} canonicalPath="/">

  <!-- Scroll progress bar -->
  <div class="progress-bar" aria-hidden="true"></div>

  <!-- ─── Hero ─────────────────────────────────────────────── -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero__content">
      <p class="hero__greeting">{t.home.greeting}</p>
      <h1 id="hero-heading" class="hero__name">{t.seo.siteName}</h1>
      <p class="hero__tagline">{t.home.tagline}</p>
      <a href={`/${lang}/blog`} class="hero__cta">{t.home.cta}</a>
    </div>
    <div class="hero__scroll-hint" aria-hidden="true">
      <span class="hero__scroll-line"></span>
    </div>
  </section>

  <!-- ─── Blog teaser ───────────────────────────────────────── -->
  <section class="section animate-on-scroll" aria-labelledby="blog-heading">
    <header class="section__header">
      <h2 id="blog-heading" class="section__title">{t.home.sections.blog}</h2>
      <a href={`/${lang}/blog`} class="section__see-all">{t.home.seeAll} →</a>
    </header>
    <ul class="card-list" role="list">
      {posts.map(post => (
        <li class="animate-on-scroll">
          <a href={`/${lang}/blog/${slugOf(post.id)}`} class="card">
            <time class="card__date" datetime={post.data.pubDate.toISOString()}>
              {dateFormatter.format(post.data.pubDate)}
            </time>
            <h3 class="card__title">{post.data.title}</h3>
            <p class="card__desc">{post.data.description}</p>
            <span class="card__read-more">{t.home.readMore} →</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- ─── Talks teaser ──────────────────────────────────────── -->
  <section class="section animate-on-scroll" aria-labelledby="talks-heading">
    <header class="section__header">
      <h2 id="talks-heading" class="section__title">{t.home.sections.talks}</h2>
      <a href={`/${lang}/talks`} class="section__see-all">{t.home.seeAll} →</a>
    </header>
    <ul class="card-list" role="list">
      {talks.map(talk => (
        <li class="animate-on-scroll">
          <a href={`/${lang}/talks/${slugOf(talk.id)}`} class="card">
            <time class="card__date" datetime={talk.data.date.toISOString()}>
              {dateFormatter.format(talk.data.date)}
            </time>
            <h3 class="card__title">{talk.data.title}</h3>
            <p class="card__desc">{talk.data.event} — {talk.data.location}</p>
            <span class="card__read-more">{t.home.readMore} →</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- ─── Gallery teaser ────────────────────────────────────── -->
  <section class="section animate-on-scroll" aria-labelledby="gallery-heading">
    <header class="section__header">
      <h2 id="gallery-heading" class="section__title">{t.home.sections.gallery}</h2>
      <a href={`/${lang}/gallery`} class="section__see-all">{t.home.seeAll} →</a>
    </header>
    <ul class="gallery-grid" role="list">
      {albums.map(album => (
        <li class="animate-on-scroll">
          <a href={`/${lang}/gallery/${slugOf(album.id)}`} class="gallery-card">
            <img
              src={album.data.coverImage}
              alt={album.data.coverImageAlt}
              class="gallery-card__img"
              loading="lazy"
              decoding="async"
            />
            <div class="gallery-card__overlay">
              <h3 class="gallery-card__title">{album.data.title}</h3>
              <p class="gallery-card__count">{t.gallery.photos(album.data.photos.length)}</p>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>

</BaseLayout>

<style>
  /* ── Scroll progress bar ───────────────────────────── */
  .progress-bar {
    position: fixed;
    inset-block-start: 0;
    inset-inline-start: 0;
    block-size: 3px;
    inline-size: 100%;
    background: var(--color-brand);
    transform-origin: left;
    z-index: var(--layer-5);

    animation: progress-grow linear;
    animation-timeline: scroll(root);
  }

  @keyframes progress-grow {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }

  /* ── Hero ──────────────────────────────────────────── */
  .hero {
    min-block-size: calc(100dvh - var(--nav-height));
    display: grid;
    place-items: center;
    text-align: center;
    padding-block: var(--size-14);
    position: relative;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--size-4);
  }

  .hero__greeting {
    font-size: var(--font-size-2);
    color: var(--text-2);
    margin: 0;

    @starting-style {
      opacity: 0;
      translate: 0 var(--size-4);
    }
    transition: opacity 0.6s, translate 0.6s;
    opacity: 1;
    translate: 0 0;
  }

  .hero__name {
    font-size: clamp(var(--font-size-6), 8vw, var(--font-size-8));
    margin: 0;
    line-height: 1;
    background: linear-gradient(135deg, var(--text-1), var(--color-brand));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;

    @starting-style {
      opacity: 0;
      scale: 0.95;
    }
    transition: opacity 0.7s 0.1s, scale 0.7s 0.1s;
    opacity: 1;
    scale: 1;
  }

  .hero__tagline {
    font-size: var(--font-size-3);
    color: var(--text-2);
    margin: 0;
    max-inline-size: 40ch;

    @starting-style {
      opacity: 0;
      translate: 0 var(--size-4);
    }
    transition: opacity 0.6s 0.2s, translate 0.6s 0.2s;
    opacity: 1;
    translate: 0 0;
  }

  .hero__cta {
    display: inline-block;
    margin-block-start: var(--size-4);
    padding: var(--size-3) var(--size-6);
    background: var(--color-brand);
    color: white;
    text-decoration: none;
    border-radius: var(--radius-3);
    font-weight: var(--font-weight-6);

    @starting-style {
      opacity: 0;
      translate: 0 var(--size-4);
    }
    transition: opacity 0.6s 0.35s, translate 0.6s 0.35s, background 0.2s;
    opacity: 1;
    translate: 0 0;

    &:hover {
      background: var(--color-brand-light);
      translate: 0 -2px;
    }
  }

  .hero__scroll-hint {
    position: absolute;
    inset-block-end: var(--size-8);
    inset-inline-start: 50%;
    translate: -50% 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero__scroll-line {
    display: block;
    inline-size: 1px;
    block-size: var(--size-10);
    background: linear-gradient(to bottom, var(--color-brand), transparent);
    animation: scroll-hint-pulse 2s ease-in-out infinite;
  }

  @keyframes scroll-hint-pulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.6) translateY(-20%); }
    50%       { opacity: 1;   transform: scaleY(1)   translateY(0); }
  }

  /* ── Sections ──────────────────────────────────────── */
  .section {
    padding-block: var(--size-14);
    border-block-start: 1px solid color-mix(in oklch, var(--text-1) 8%, transparent);
  }

  .section__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-block-end: var(--size-8);
  }

  .section__title {
    font-size: var(--font-size-4);
    margin: 0;
  }

  .section__see-all {
    font-size: var(--font-size-0);
    color: var(--text-2);
    text-decoration: none;
    transition: color 0.2s;

    &:hover { color: var(--color-brand); }
  }

  /* ── Blog / Talks cards ────────────────────────────── */
  .card-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--size-4);
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: var(--size-2);
    padding: var(--size-5);
    background: var(--surface-2);
    border-radius: var(--radius-3);
    text-decoration: none;
    color: inherit;
    border: 1px solid color-mix(in oklch, var(--text-1) 8%, transparent);
    transition: translate 0.2s, box-shadow 0.2s;

    &:hover {
      translate: 0 -3px;
      box-shadow: var(--shadow-3);
    }
  }

  .card__date {
    font-size: var(--font-size-00);
    color: var(--text-2);
  }

  .card__title {
    font-size: var(--font-size-1);
    margin: 0;
    color: var(--text-1);
  }

  .card__desc {
    font-size: var(--font-size-0);
    color: var(--text-2);
    margin: 0;
    flex: 1;
  }

  .card__read-more {
    font-size: var(--font-size-0);
    color: var(--color-brand);
    margin-block-start: var(--size-2);
  }

  /* ── Gallery grid ──────────────────────────────────── */
  .gallery-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--size-3);
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 240px), 1fr));
  }

  .gallery-card {
    position: relative;
    display: block;
    aspect-ratio: 4/3;
    border-radius: var(--radius-3);
    overflow: hidden;
    text-decoration: none;
    color: white;

    &:hover .gallery-card__img {
      transform: scale(1.05);
    }

    &:hover .gallery-card__overlay {
      opacity: 1;
    }
  }

  .gallery-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .gallery-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, color-mix(in oklch, black 70%, transparent), transparent);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--size-4);
    opacity: 0.8;
    transition: opacity 0.3s;
  }

  .gallery-card__title {
    margin: 0;
    font-size: var(--font-size-1);
  }

  .gallery-card__count {
    margin: 0;
    font-size: var(--font-size-00);
    opacity: 0.8;
  }
</style>
