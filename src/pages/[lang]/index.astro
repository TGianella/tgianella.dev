---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  useTranslations,
  getLocaleStaticPaths,
  slugOf,
  isUpcoming,
  type Locale,
} from "../../i18n/utils";
import { getCollection } from "astro:content";
import { debutEvent } from "../../content/utils";
import Portrait from "../../assets/portrait-theo-gianella-2.jpg";

export const getStaticPaths = getLocaleStaticPaths;

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);

const posts = (
  await getCollection("blog", ({ id }) => id.startsWith(`${lang}/`))
)
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const talks = (
  await getCollection("talks", ({ id }) => id.startsWith(`${lang}/`))
)
  .sort((a, b) => {
    const aMin = Math.min(...a.data.events.map((e) => e.date.valueOf()));
    const bMin = Math.min(...b.data.events.map((e) => e.date.valueOf()));
    return bMin - aMin;
  })
  .slice(0, 3);

const recentPhotos = (
  await getCollection("gallery", ({ id }) => id.startsWith(`${lang}/`))
)
  .sort((a, b) => {
    if (!a.data.date && !b.data.date) return 0;
    if (!a.data.date) return 1;
    if (!b.data.date) return -1;
    return b.data.date.valueOf() - a.data.date.valueOf();
  })
  .slice(0, 4);

const dateFormatter = new Intl.DateTimeFormat(lang, { dateStyle: "medium" });
---

<BaseLayout lang={lang} description={t.home.tagline} canonicalPath="/">
  <section class="hero">
    <div class="hero__name-container">
      <h1 class="hero__name">{t.seo.siteName}</h1>
      <img
        src={Portrait.src}
        alt={t.seo.siteName}
        class="hero__avatar"
        width="646"
        height="363"
      />
    </div>

    <div class="hero__bottom">
      <p class="hero__tagline" data-vt-name="hero-tagline">{t.home.tagline}</p>
      <span class="hero__scroll-hint" aria-hidden="true">↓</span>
    </div>
  </section>

  <section class="section">
    {t.home.bio.map((p) => <p>{p}</p>)}
  </section>

  <section class="section">
    <header class="section__header">
      <h2 class="section__title">{t.home.sections.blog}</h2>
      <a href={`/${lang}/blog`} class="section__see-all">{t.home.seeAll} →</a>
    </header>
    <ul class="card-grid">
      {
        posts.map((post) => (
          <li>
            <a href={`/${lang}/blog/${slugOf(post.id, lang)}`} class="card">
              <time
                class="card__date"
                datetime={post.data.pubDate.toISOString()}
              >
                {dateFormatter.format(post.data.pubDate)}
              </time>
              <h3 class="card__title">{post.data.title}</h3>
              <p class="card__desc">{post.data.description}</p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="section">
    <header class="section__header">
      <h2 class="section__title">{t.home.sections.talks}</h2>
      <a href={`/${lang}/talks`} class="section__see-all">{t.home.seeAll} →</a>
    </header>
    <ul class="card-grid">
      {
        talks.map((talk) => {
          const debut = debutEvent(talk.data.events);
          const upcoming = isUpcoming(talk.data.events);
          return (
            <li>
              <a href={`/${lang}/talks/${slugOf(talk.id, lang)}`} class="card">
                <div class="card__meta">
                  <time class="card__date" datetime={debut.date.toISOString()}>
                    {dateFormatter.format(debut.date)}
                  </time>
                  {upcoming && (
                    <span class="upcoming-pill">{t.talks.upcoming}</span>
                  )}
                </div>
                <h3 class="card__title">{talk.data.title}</h3>
                <p class="card__desc">
                  {debut.name} — {debut.location}
                </p>
              </a>
            </li>
          );
        })
      }
    </ul>
  </section>

  <section class="section">
    <header class="section__header">
      <h2 class="section__title">{t.home.sections.gallery}</h2>
      <a href={`/${lang}/blue-screens`} class="section__see-all"
        >{t.home.seeAll} →</a
      >
    </header>
    <ul class="gallery-grid">
      {
        recentPhotos.map((photo) => (
          <li>
            <a
              href={`/${lang}/blue-screens/${slugOf(photo.id, lang)}`}
              class="gallery-card"
            >
              <img
                src={photo.data.src.replace(
                  /\/([^/]+)\.[^.]+$/,
                  "/thumbnails/$1.webp",
                )}
                alt={photo.data.alt}
                width={400}
                height={300}
                class="gallery-card__img"
                loading="lazy"
                decoding="async"
              />
              {photo.data.location && (
                <div class="gallery-card__caption">
                  <span class="gallery-card__title">{photo.data.location}</span>
                </div>
              )}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    padding-block: var(--size-7);
    border-block-end: var(--border-size-1) solid var(--border);
    margin-block-end: var(--size-8);
    min-block-size: calc(100dvh - ((var(--size-7) * 2) + var(--size-5)));
  }

  .hero__name-container {
    display: flex;
    flex-direction: column;
    gap: var(--size-5);
    margin-block: auto var(--size-6);
  }

  .hero__name {
    width: min-content;
    font-size: clamp(1.5rem, 10vmax, 12rem);
    margin: 0;
    line-height: 0.8;
  }

  .hero__avatar {
    object-fit: cover;
    max-width: 100%;
  }

  .hero__tagline {
    font-size: clamp(1.5rem, 6vmax, 10rem);
    line-height: 0.9;
    color: var(--text-2);
    margin: 0;
    width: min-content;
    font-family: var(--font-transitional);
    view-transition-class: text-transition;
    padding-block-end: 0.2em;
  }

  .hero__scroll-hint {
    display: block;
    text-align: end;
    font-size: clamp(3rem, 10vmax, 8rem);
    color: var(--text-2);
    line-height: 1;
    font-family: var(--font-transitional);
    margin-block-start: var(--size-4);
  }

  @media (width >= 48rem) {
    .hero {
      position: relative;
      align-items: center;
      gap: var(--size-1);
      padding-block: var(--size-9);
      padding-inline: 10vw;
      min-block-size: calc(100dvh - (var(--size-9) * 2));
    }

    .hero__name-container {
      position: absolute;
      top: var(--size-1);
      left: min(
        calc((100vw - var(--layout-width)) / -2 + var(--size-5)),
        var(--size-5)
      );
      max-width: min-content;
      gap: 0;
    }

    .hero__avatar {
      position: relative;
      left: var(--size-2);
      margin-block-start: var(--size-5);
    }

    .hero__bottom {
      display: contents;
    }

    .hero__tagline {
      position: absolute;
      right: min(
        calc((100vw - var(--layout-width)) / -2 + var(--size-5)),
        var(--size-5)
      );
      bottom: calc(var(--size-7) - 0.2em);
      width: min-content;
      text-align: end;
      font-size: clamp(2rem, 8vmax, 10rem);
      view-transition-class: text-transition-right;
    }

    .hero__scroll-hint {
      position: absolute;
      bottom: var(--size-5);
      left: min(
        calc((100vw - var(--layout-width)) / -2 + var(--size-5)),
        var(--size-5)
      );
      margin-block-start: 0;
    }
  }

  /* ── Sections ──────────────────────────────────────── */
  .section {
    padding-block-end: var(--size-8);
    margin-block-end: var(--size-8);
    border-block-end: var(--border-size-1) solid var(--border);

    &:last-child {
      border-block-end: none;
      margin-block-end: 0;
      padding-block-end: 0;
    }
  }

  .section__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--size-3);
    margin-block-end: var(--size-4);
  }

  .section__title {
    font-size: var(--font-size-4);
    margin: 0;
  }

  .section__see-all {
    font-size: var(--font-size-1);
    color: var(--text-2);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s;

    &:hover {
      color: var(--color-brand);
    }
  }

  /* ── Content cards ─────────────────────────────────── */
  .card-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--size-3);
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 260px), 1fr));
  }

  .card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 0.375rem;
    padding: var(--size-3);
    background: var(--surface-2);
    border-radius: var(--radius-2);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s;
    block-size: 100%;
  }

  .card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--size-2);
  }

  .card__date {
    font-size: var(--font-size-0);
    color: var(--text-2);
  }

  .card__title {
    font-size: var(--font-size-2);
    font-weight: var(--font-weight-6);
    margin: 0;
    color: var(--text-1);
  }

  .card__desc {
    font-size: var(--font-size-1);
    color: var(--text-2);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Gallery grid ──────────────────────────────────── */
  .gallery-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(auto-fill, minmax(min(40dvw, 200px), 1fr));
  }

  .gallery-card {
    display: block;
    border-radius: var(--radius-2);
    overflow: hidden;
    text-decoration: none;
    color: var(--text-1);
  }

  .gallery-card__img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  .gallery-card__caption {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--size-2);
    padding: 0.625rem 0.75rem;
    font-size: var(--font-size-1);
  }

  .gallery-card__title {
    font-weight: var(--font-weight-6);
    color: var(--text-1);
  }
</style>
