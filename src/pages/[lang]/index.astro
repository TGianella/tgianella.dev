---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations, getLocaleStaticPaths, slugOf, isUpcoming, type Locale } from '../../i18n/utils';
import { getCollection } from 'astro:content';

export const getStaticPaths = getLocaleStaticPaths;

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);

const posts = (await getCollection('blog', ({ id }) => id.startsWith(`${lang}/`)))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const talks = (await getCollection('talks', ({ id }) => id.startsWith(`${lang}/`)))
  .sort((a, b) => {
    const aMin = Math.min(...a.data.events.map(e => e.date.valueOf()));
    const bMin = Math.min(...b.data.events.map(e => e.date.valueOf()));
    return bMin - aMin;
  })
  .slice(0, 3);

const albums = (await getCollection('gallery', ({ id }) => id.startsWith(`${lang}/`)))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const dateFormatter = new Intl.DateTimeFormat(lang, { dateStyle: 'medium' });
---

<BaseLayout lang={lang} title={t.nav.home} description={t.home.tagline} canonicalPath="/">

  <section class="hero">
    <p class="hero__greeting">{t.home.greeting}</p>
    <h1 class="hero__name">{t.seo.siteName}</h1>
    <p class="hero__tagline">{t.home.tagline}</p>
    <a href={`/${lang}/blog`} class="hero__cta">{t.home.cta}</a>
  </section>

  <section class="section">
    <header class="section__header">
      <h2 class="section__title">{t.home.sections.blog}</h2>
      <a href={`/${lang}/blog`} class="section__see-all">{t.home.seeAll} →</a>
    </header>
    <ul class="card-grid">
      {posts.map(post => (
        <li>
          <a href={`/${lang}/blog/${slugOf(post.id, lang)}`} class="card">
            <time class="card__date" datetime={post.data.pubDate.toISOString()}>
              {dateFormatter.format(post.data.pubDate)}
            </time>
            <h3 class="card__title">{post.data.title}</h3>
            <p class="card__desc">{post.data.description}</p>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <section class="section">
    <header class="section__header">
      <h2 class="section__title">{t.home.sections.talks}</h2>
      <a href={`/${lang}/talks`} class="section__see-all">{t.home.seeAll} →</a>
    </header>
    <ul class="card-grid">
      {talks.map(talk => {
        const latest = talk.data.events.reduce((a, b) => b.date > a.date ? b : a);
        const upcoming = isUpcoming(talk.data.events);
        return (
          <li>
            <a href={`/${lang}/talks/${slugOf(talk.id, lang)}`} class="card">
              <div class="card__meta">
                <time class="card__date" datetime={latest.date.toISOString()}>
                  {dateFormatter.format(latest.date)}
                </time>
                {upcoming && <span class="upcoming-pill">{t.talks.upcoming}</span>}
              </div>
              <h3 class="card__title">{talk.data.title}</h3>
              <p class="card__desc">{latest.name} — {latest.location}</p>
            </a>
          </li>
        );
      })}
    </ul>
  </section>

  <section class="section">
    <header class="section__header">
      <h2 class="section__title">{t.home.sections.gallery}</h2>
      <a href={`/${lang}/gallery`} class="section__see-all">{t.home.seeAll} →</a>
    </header>
    <ul class="gallery-grid">
      {albums.map(album => (
        <li>
          <a href={`/${lang}/gallery/${slugOf(album.id, lang)}`} class="gallery-card">
            <img
              src={album.data.coverImage}
              alt={album.data.coverImageAlt}
              class="gallery-card__img"
              loading="lazy"
              decoding="async"
            />
            <div class="gallery-card__caption">
              <span class="gallery-card__title">{album.data.title}</span>
              <span class="gallery-card__count">{t.gallery.photos(album.data.photos.length)}</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>

</BaseLayout>

<style>
  .hero {
    padding-block: var(--size-9);
    border-block-end: var(--border-size-1) solid var(--border);
    margin-block-end: var(--size-8);
  }

  .hero__greeting {
    color: var(--text-2);
    margin: 0 0 var(--size-1);
    font-size: var(--font-size-2);
  }

  .hero__name {
    font-size: clamp(2rem, 6vw, 3.5rem);
    margin: 0 0 0.75rem;
  }

  .hero__tagline {
    font-size: var(--font-size-2);
    color: var(--text-2);
    margin: 0 0 var(--size-5);
    max-inline-size: 45ch;
  }

  .hero__cta {
    display: inline-block;
    padding: 0.625rem var(--size-4);
    background: var(--color-brand);
    color: white;
    text-decoration: none;
    border-radius: var(--radius-2);
    font-weight: var(--font-weight-6);
    font-size: var(--font-size-1);
    transition: opacity 0.15s;

    &:hover { opacity: 0.85; }
  }

  /* ── Sections ──────────────────────────────────────── */
  .section {
    padding-block-end: var(--size-8);
    margin-block-end: var(--size-8);
    border-block-end: var(--border-size-1) solid var(--border);

    &:last-child {
      border-block-end: none;
      margin-block-end: 0;
    }
  }

  .section__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--size-3);
    margin-block-end: var(--size-4);
  }

  .section__title {
    font-size: var(--font-size-3);
    margin: 0;
  }

  .section__see-all {
    font-size: var(--font-size-1);
    color: var(--text-2);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s;

    &:hover { color: var(--color-brand); }
  }

  /* ── Content cards ─────────────────────────────────── */
  .card-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--size-3);
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 260px), 1fr));
  }

  .card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 0.375rem;
    padding: var(--size-3);
    background: var(--surface-2);
    border: var(--border-size-1) solid var(--border);
    border-radius: var(--radius-2);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s;
    block-size: 100%;

    &:hover {
      border-color: var(--color-brand);
    }
  }

  .card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--size-2);
  }

  .card__date {
    font-size: var(--font-size-0);
    color: var(--text-2);
  }

  .card__title {
    font-size: var(--font-size-2);
    font-weight: var(--font-weight-6);
    margin: 0;
    color: var(--text-1);
  }

  .card__desc {
    font-size: var(--font-size-1);
    color: var(--text-2);
    margin: 0;
  }

  /* ── Gallery grid ──────────────────────────────────── */
  .gallery-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 200px), 1fr));
  }

  .gallery-card {
    display: block;
    border-radius: var(--radius-2);
    overflow: hidden;
    text-decoration: none;
    color: var(--text-1);
    border: var(--border-size-1) solid var(--border);
    transition: border-color 0.15s;

    &:hover {
      border-color: var(--color-brand);
    }
  }

  .gallery-card__img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  .gallery-card__caption {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--size-2);
    padding: 0.625rem 0.75rem;
    font-size: var(--font-size-1);
  }

  .gallery-card__title {
    font-weight: var(--font-weight-6);
    color: var(--text-1);
  }

  .gallery-card__count {
    color: var(--text-2);
    white-space: nowrap;
  }
</style>
