---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations, getLocaleStaticPaths, slugOf, isUpcoming, type Locale } from '../../i18n/utils';
import { getCollection } from 'astro:content';
import Portrait from '../../assets/portrait-theo-gianella.jpg';

export const getStaticPaths = getLocaleStaticPaths;

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);

const posts = (await getCollection('blog', ({ id }) => id.startsWith(`${lang}/`)))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const talks = (await getCollection('talks', ({ id }) => id.startsWith(`${lang}/`)))
  .sort((a, b) => {
    const aMin = Math.min(...a.data.events.map(e => e.date.valueOf()));
    const bMin = Math.min(...b.data.events.map(e => e.date.valueOf()));
    return bMin - aMin;
  })
  .slice(0, 3);

const albums = (await getCollection('gallery', ({ id }) => id.startsWith(`${lang}/`)))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const dateFormatter = new Intl.DateTimeFormat(lang, { dateStyle: 'medium' });
---

<BaseLayout lang={lang} title={t.nav.home} description={t.home.tagline} canonicalPath="/">

  <section class="hero">
    <img
      src={Portrait.src}
      alt={t.seo.siteName}
      class="hero__avatar"
      width="128"
      height="128"
    />
    <h1 class="hero__name">{t.seo.siteName}</h1>
    <p class="hero__tagline">{t.home.tagline}</p>
    <div class="hero__links">
      <a href="https://github.com/TGianella" aria-label={t.home.github} class="hero__link">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </a>
      <a href="https://www.linkedin.com/in/théo-gianella" aria-label={t.home.linkedin} class="hero__link">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
    </div>
  </section>

  <section class="section">
    <header class="section__header">
      <h2 class="section__title">{t.home.sections.blog}</h2>
      <a href={`/${lang}/blog`} class="section__see-all">{t.home.seeAll} →</a>
    </header>
    <ul class="card-grid">
      {posts.map(post => (
        <li>
          <a href={`/${lang}/blog/${slugOf(post.id, lang)}`} class="card">
            <time class="card__date" datetime={post.data.pubDate.toISOString()}>
              {dateFormatter.format(post.data.pubDate)}
            </time>
            <h3 class="card__title">{post.data.title}</h3>
            <p class="card__desc">{post.data.description}</p>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <section class="section">
    <header class="section__header">
      <h2 class="section__title">{t.home.sections.talks}</h2>
      <a href={`/${lang}/talks`} class="section__see-all">{t.home.seeAll} →</a>
    </header>
    <ul class="card-grid">
      {talks.map(talk => {
        const latest = talk.data.events.reduce((a, b) => b.date > a.date ? b : a);
        const upcoming = isUpcoming(talk.data.events);
        return (
          <li>
            <a href={`/${lang}/talks/${slugOf(talk.id, lang)}`} class="card">
              <div class="card__meta">
                <time class="card__date" datetime={latest.date.toISOString()}>
                  {dateFormatter.format(latest.date)}
                </time>
                {upcoming && <span class="upcoming-pill">{t.talks.upcoming}</span>}
              </div>
              <h3 class="card__title">{talk.data.title}</h3>
              <p class="card__desc">{latest.name} — {latest.location}</p>
            </a>
          </li>
        );
      })}
    </ul>
  </section>

  <section class="section">
    <header class="section__header">
      <h2 class="section__title">{t.home.sections.gallery}</h2>
      <a href={`/${lang}/gallery`} class="section__see-all">{t.home.seeAll} →</a>
    </header>
    <ul class="gallery-grid">
      {albums.map(album => (
        <li>
          <a href={`/${lang}/gallery/${slugOf(album.id, lang)}`} class="gallery-card">
            <img
              src={album.data.coverImage}
              alt={album.data.coverImageAlt}
              class="gallery-card__img"
              loading="lazy"
              decoding="async"
            />
            <div class="gallery-card__caption">
              <span class="gallery-card__title">{album.data.title}</span>
              <span class="gallery-card__count">{t.gallery.photos(album.data.photos.length)}</span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>

</BaseLayout>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--size-1);
    padding-block: var(--size-9);
    border-block-end: var(--border-size-1) solid var(--border);
    margin-block-end: var(--size-8);
  }

  .hero__avatar {
    width: 7rem;
    height: 7rem;
    border-radius: var(--radius-round);
    object-fit: cover;
  }

  .hero__name {
    font-size: clamp(2rem, 6vw, 3.5rem);
    margin: 0;
  }

  .hero__tagline {
    font-size: var(--font-size-2);
    color: var(--text-2);
    margin: 0;
  }

  .hero__links {
    display: flex;
    gap: var(--size-4);
    align-items: center;
    margin-block-start: var(--size-2);
  }

  .hero__link {
    display: flex;
    color: var(--text-2);
    text-decoration: none;
    transition: color 0.15s;

    &:hover { color: var(--color-brand); }

    & svg {
      width: 1.5rem;
      height: 1.5rem;
    }
  }

  /* ── Sections ──────────────────────────────────────── */
  .section {
    padding-block-end: var(--size-8);
    margin-block-end: var(--size-8);
    border-block-end: var(--border-size-1) solid var(--border);

    &:last-child {
      border-block-end: none;
      margin-block-end: 0;
    }
  }

  .section__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--size-3);
    margin-block-end: var(--size-4);
  }

  .section__title {
    font-size: var(--font-size-3);
    margin: 0;
  }

  .section__see-all {
    font-size: var(--font-size-1);
    color: var(--text-2);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s;

    &:hover { color: var(--color-brand); }
  }

  /* ── Content cards ─────────────────────────────────── */
  .card-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--size-3);
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 260px), 1fr));
  }

  .card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 0.375rem;
    padding: var(--size-3);
    background: var(--surface-2);
    border: var(--border-size-1) solid var(--border);
    border-radius: var(--radius-2);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s;
    block-size: 100%;

    &:hover {
      border-color: var(--color-brand);
    }
  }

  .card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--size-2);
  }

  .card__date {
    font-size: var(--font-size-0);
    color: var(--text-2);
  }

  .card__title {
    font-size: var(--font-size-2);
    font-weight: var(--font-weight-6);
    margin: 0;
    color: var(--text-1);
  }

  .card__desc {
    font-size: var(--font-size-1);
    color: var(--text-2);
    margin: 0;
  }

  /* ── Gallery grid ──────────────────────────────────── */
  .gallery-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 200px), 1fr));
  }

  .gallery-card {
    display: block;
    border-radius: var(--radius-2);
    overflow: hidden;
    text-decoration: none;
    color: var(--text-1);
    border: var(--border-size-1) solid var(--border);
    transition: border-color 0.15s;

    &:hover {
      border-color: var(--color-brand);
    }
  }

  .gallery-card__img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  .gallery-card__caption {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--size-2);
    padding: 0.625rem 0.75rem;
    font-size: var(--font-size-1);
  }

  .gallery-card__title {
    font-weight: var(--font-weight-6);
    color: var(--text-1);
  }

  .gallery-card__count {
    color: var(--text-2);
    white-space: nowrap;
  }
</style>
