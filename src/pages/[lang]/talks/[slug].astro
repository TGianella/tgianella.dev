---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations, locales, type Locale } from '../../../i18n/utils';
import { getCollection, render } from 'astro:content';
import EventCard from '../../../components/EventCard.astro';

export async function getStaticPaths() {
  const talks = await getCollection('talks');
  return talks.flatMap(talk => {
    const [lang, ...slugParts] = talk.id.split('/');
    if (!locales.includes(lang as Locale)) return [];
    return [{
      params: { lang, slug: slugParts.join('/') },
      props: { talk },
    }];
  });
}

const { lang, slug } = Astro.params as { lang: Locale; slug: string };
const { talk } = Astro.props;
const t = useTranslations(lang);
const { Content } = await render(talk);

const videoId = talk.data.featuredVideo ?? talk.data.events.find(e => e.videoId)?.videoId;
const videoTimestamp = talk.data.events.find(e => e.videoId === videoId)?.timestamp;
const eventsSorted = [...talk.data.events].sort((a, b) => b.date.valueOf() - a.date.valueOf());
---

<BaseLayout lang={lang} title={talk.data.title} description={talk.data.description} canonicalPath={`/talks/${slug}`}>
  <article>
    <a href={`/${lang}/talks`} class="back-link">{t.talks.backToList}</a>

    <header class="talk-header">
      <h1 class="talk-header__title">{talk.data.title}</h1>

      {talk.data.coSpeakers.length > 0 && (
        <div class="talk-header__cospeakers">
          <span class="talk-header__cospeakers-label">{t.talks.with}</span>
          {talk.data.coSpeakers.map(s => {
            const picture = s.picture ?? `https://picsum.photos/seed/${encodeURIComponent(s.name)}/64/64`;
            return (
              <span class="cospeaker">
                <img class="cospeaker__avatar" src={picture} alt={s.name} width="24" height="24" />
                {s.url
                  ? <a href={s.url} target="_blank" rel="noopener noreferrer">{s.name}</a>
                  : <span>{s.name}</span>
                }
              </span>
            );
          })}
        </div>
      )}

      <div class="talk-header__actions">
        {videoId && (
          <a href="#video" class="btn btn--primary">{t.talks.watchTalk} ↓</a>
        )}
        {talk.data.slides && (
          <a href={talk.data.slides} target="_blank" rel="noopener noreferrer" class="btn btn--secondary">
            {t.talks.viewSlides} ↗
          </a>
        )}
      </div>

      {talk.data.tags.length > 0 && (
        <ul class="tag-list" role="list">
          {talk.data.tags.map(tag => <li class="tag">{tag}</li>)}
        </ul>
      )}
    </header>

    <div class="talk-layout">
      <div class="talk-main">
        <section class="abstract">
          {talk.data.abstract.split('\n').filter(p => p.trim()).map(p => (
            <p>{p}</p>
          ))}
        </section>

        {videoId && (
          <section id="video" class="video-section">
            <div class="video-wrapper">
              <iframe
                src={`https://www.youtube.com/embed/${videoId}${videoTimestamp ? `?start=${videoTimestamp}` : ''}`}
                title={talk.data.title}
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            </div>
          </section>
        )}

        <div class="prose">
          <Content />
        </div>
      </div>

      <aside class="events-sidebar">
        <h2 class="events-sidebar__heading">{t.talks.events}</h2>
        <ul class="event-list" role="list">
          {eventsSorted.map(event => (
            <EventCard event={event} lang={lang} />
          ))}
        </ul>
      </aside>
    </div>
  </article>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    font-size: var(--font-size-1);
    color: var(--text-2);
    text-decoration: none;
    margin-block-end: var(--size-5);
    transition: color 0.15s;

    &:hover { color: var(--color-brand); }
  }

  .talk-header {
    margin-block-end: var(--size-5);
    padding-block-end: var(--size-5);
    border-block-end: var(--border-size-1) solid var(--border);
  }

  .talk-header__title {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    margin: 0 0 var(--size-4);
  }

  .talk-header__cospeakers {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--size-3);
    margin: 0 0 var(--size-5);
  }

  .talk-header__cospeakers-label {
    font-size: var(--font-size-1);
    color: var(--text-2);
  }

  .cospeaker {
    display: flex;
    align-items: center;
    gap: var(--size-1);
    font-size: var(--font-size-1);

    & a { color: var(--color-brand); text-decoration: none; }
    & a:hover { text-decoration: underline; }
  }

  .cospeaker__avatar {
    border-radius: var(--radius-round);
    object-fit: cover;
    block-size: 1.5rem;
    inline-size: 1.5rem;
  }

  .talk-header__actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-block-end: var(--size-4);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--size-1);
    padding: var(--size-2) var(--size-3);
    border-radius: var(--radius-2);
    font-size: var(--font-size-1);
    font-weight: var(--font-weight-6);
    text-decoration: none;
    transition: opacity 0.15s;

    &:hover { opacity: 0.85; }
  }

  .btn--primary {
    background: var(--color-brand);
    color: white;
  }

  .btn--secondary {
    background: var(--surface-2);
    color: var(--text-1);
    border: var(--border-size-1) solid var(--border);
  }

  .talk-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--size-8);
    align-items: start;
  }

  @media (width >= 48rem) {
    .talk-layout {
      grid-template-columns: 2fr 1fr;
    }
  }

  .abstract {
    font-size: var(--font-size-2);
    color: var(--text-2);
    line-height: 1.7;
    max-inline-size: 70ch;
    margin-block-end: var(--size-8);
  }

  .events-sidebar__heading {
    font-size: var(--font-size-2);
    margin: 0 0 var(--size-3);
  }

  .event-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--size-2);
  }

.video-section {
    margin-block-end: var(--size-8);
  }

  .video-wrapper {
    position: relative;
    aspect-ratio: 16/9;
    border-radius: var(--radius-2);
    overflow: hidden;
    background: var(--surface-3);

    & iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: 0;
    }
  }
</style>
