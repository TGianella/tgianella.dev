---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations, locales, type Locale } from '../../../i18n/utils';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const talks = await getCollection('talks');
  return talks.flatMap(talk => {
    const [lang, ...slugParts] = talk.id.split('/');
    if (!locales.includes(lang as Locale)) return [];
    return [{
      params: { lang, slug: slugParts.join('/') },
      props: { talk },
    }];
  });
}

const { lang, slug } = Astro.params as { lang: Locale; slug: string };
const { talk } = Astro.props;
const t = useTranslations(lang);
const { Content } = await render(talk);

const dateFormatter = new Intl.DateTimeFormat(lang, { dateStyle: 'long' });

const videoId = talk.data.featuredVideo ?? talk.data.events.find(e => e.videoId)?.videoId;
const eventsSorted = [...talk.data.events].sort((a, b) => b.date.valueOf() - a.date.valueOf());
---

<BaseLayout lang={lang} title={talk.data.title} description={talk.data.description} canonicalPath={`/talks/${slug}`}>
  <article>
    <a href={`/${lang}/talks`} class="back-link">{t.talks.backToList}</a>

    <header class="talk-header">
      <h1 class="talk-header__title">{talk.data.title}</h1>

      {talk.data.coSpeakers.length > 0 && (
        <p class="talk-header__cospeakers">
          {t.talks.with}{' '}
          {talk.data.coSpeakers.map((s, i) => (
            <>
              {s.url
                ? <a href={s.url} target="_blank" rel="noopener noreferrer">{s.name}</a>
                : <span>{s.name}</span>
              }
              {i < talk.data.coSpeakers.length - 1 && ', '}
            </>
          ))}
        </p>
      )}

      <div class="talk-header__actions">
        {videoId && (
          <a href="#video" class="btn btn--primary">{t.talks.watchTalk} ↓</a>
        )}
        {talk.data.slides && (
          <a href={talk.data.slides} target="_blank" rel="noopener noreferrer" class="btn btn--secondary">
            {t.talks.viewSlides} ↗
          </a>
        )}
      </div>

      {talk.data.tags.length > 0 && (
        <ul class="tag-list" role="list">
          {talk.data.tags.map(tag => <li class="tag">{tag}</li>)}
        </ul>
      )}
    </header>

    <section class="abstract">
      <p>{talk.data.abstract}</p>
    </section>

    <section class="events-section">
      <h2 class="events-section__heading">{t.talks.events}</h2>
      <ul class="event-list" role="list">
        {eventsSorted.map(event => (
          <li class="event-item">
            <time class="event-item__date" datetime={event.date.toISOString()}>
              {dateFormatter.format(event.date)}
            </time>
            <div class="event-item__body">
              <span class="event-item__name">
                {event.url
                  ? <a href={event.url} target="_blank" rel="noopener noreferrer">{event.name} ↗</a>
                  : event.name
                }
              </span>
              <span class="event-item__location">{event.location}</span>
            </div>
            {event.videoId && (
              <a href={`https://www.youtube.com/watch?v=${event.videoId}`} target="_blank" rel="noopener noreferrer" class="event-item__video-badge" aria-label="Watch video">
                ▶ video
              </a>
            )}
          </li>
        ))}
      </ul>
    </section>

    {videoId && (
      <section id="video" class="video-section">
        <div class="video-wrapper">
          <iframe
            src={`https://www.youtube.com/embed/${videoId}`}
            title={talk.data.title}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
      </section>
    )}

    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    font-size: var(--font-size-1);
    color: var(--text-2);
    text-decoration: none;
    margin-block-end: var(--size-5);
    transition: color 0.15s;

    &:hover { color: var(--color-brand); }
  }

  .talk-header {
    margin-block-end: var(--size-5);
    padding-block-end: var(--size-5);
    border-block-end: var(--border-size-1) solid var(--border);
  }

  .talk-header__title {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    margin: 0 0 var(--size-2);
  }

  .talk-header__cospeakers {
    font-size: var(--font-size-1);
    color: var(--text-2);
    margin: 0 0 var(--size-3);

    & a { color: var(--color-brand); }
  }

  .talk-header__actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-block-end: 0.875rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--size-1);
    padding: var(--size-2) var(--size-3);
    border-radius: var(--radius-2);
    font-size: var(--font-size-1);
    font-weight: var(--font-weight-6);
    text-decoration: none;
    transition: opacity 0.15s;

    &:hover { opacity: 0.85; }
  }

  .btn--primary {
    background: var(--color-brand);
    color: white;
  }

  .btn--secondary {
    background: var(--surface-2);
    color: var(--text-1);
    border: var(--border-size-1) solid var(--border);
  }

  .abstract {
    font-size: var(--font-size-2);
    color: var(--text-2);
    line-height: 1.7;
    max-inline-size: 60ch;
    margin-block-end: var(--size-8);
  }

  .events-section {
    margin-block-end: var(--size-8);
  }

  .events-section__heading {
    font-size: var(--font-size-2);
    margin: 0 0 var(--size-3);
  }

  .event-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--size-2);
  }

  .event-item {
    display: flex;
    align-items: center;
    gap: var(--size-3);
    padding: var(--size-3);
    background: var(--surface-2);
    border-radius: var(--radius-2);
    flex-wrap: wrap;
  }

  .event-item__date {
    font-size: var(--font-size-0);
    color: var(--text-2);
    white-space: nowrap;
    min-inline-size: 8rem;
  }

  .event-item__body {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    flex: 1;
  }

  .event-item__name {
    font-size: var(--font-size-1);
    font-weight: var(--font-weight-6);

    & a {
      color: inherit;
      text-decoration: none;
      &:hover { color: var(--color-brand); }
    }
  }

  .event-item__location {
    font-size: var(--font-size-0);
    color: var(--text-2);
  }

  .event-item__video-badge {
    font-size: var(--font-size-0);
    color: var(--color-brand);
    border: var(--border-size-1) solid var(--color-brand);
    border-radius: var(--radius-round);
    padding: var(--border-size-1) var(--size-2);
    text-decoration: none;
    white-space: nowrap;

    &:hover { opacity: 0.8; }
  }

  .video-section {
    margin-block-end: var(--size-8);
  }

  .video-wrapper {
    position: relative;
    aspect-ratio: 16/9;
    border-radius: var(--radius-2);
    overflow: hidden;
    background: var(--surface-3);

    & iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: 0;
    }
  }
</style>
