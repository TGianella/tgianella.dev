---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations, locales, type Locale } from '../../../i18n/utils';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const talks = await getCollection('talks');
  return talks.flatMap(talk => {
    const [lang, ...slugParts] = talk.id.split('/');
    if (!locales.includes(lang as Locale)) return [];
    return [{
      params: { lang, slug: slugParts.join('/') },
      props: { talk },
    }];
  });
}

const { lang, slug } = Astro.params as { lang: Locale; slug: string };
const { talk } = Astro.props;
const t = useTranslations(lang);
const { Content } = await render(talk);

const dateFormatter = new Intl.DateTimeFormat(lang, { dateStyle: 'long' });
---

<BaseLayout lang={lang} title={talk.data.title} description={talk.data.description} canonicalPath={`/talks/${slug}`}>
  <article>
    <a href={`/${lang}/talks`} class="back-link">{t.talks.backToList}</a>

    <header class="talk-header">
      <div class="talk-header__meta">
        <time datetime={talk.data.date.toISOString()}>
          {dateFormatter.format(talk.data.date)}
        </time>
        <span>·</span>
        <span>
          {t.talks.at} {talk.data.event}
          {talk.data.eventUrl && (
            <a href={talk.data.eventUrl} target="_blank" rel="noopener noreferrer">↗</a>
          )}
        </span>
        <span>·</span>
        <span>{talk.data.location}</span>
      </div>

      <h1 class="talk-header__title">{talk.data.title}</h1>

      <div class="talk-header__actions">
        {talk.data.videoId && (
          <a href="#video" class="btn btn--primary">{t.talks.watchTalk} ↓</a>
        )}
        {talk.data.slides && (
          <a href={talk.data.slides} target="_blank" rel="noopener noreferrer" class="btn btn--secondary">
            {t.talks.viewSlides} ↗
          </a>
        )}
      </div>

      {talk.data.tags.length > 0 && (
        <ul class="tag-list" role="list">
          {talk.data.tags.map(tag => <li class="tag">{tag}</li>)}
        </ul>
      )}
    </header>

    <section class="abstract">
      <p>{talk.data.abstract}</p>
    </section>

    {talk.data.videoId && (
      <section id="video" class="video-section">
        <div class="video-wrapper">
          <iframe
            src={`https://www.youtube.com/embed/${talk.data.videoId}`}
            title={talk.data.title}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
      </section>
    )}

    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--text-2);
    text-decoration: none;
    margin-block-end: var(--space-md);
    transition: color 0.15s;

    &:hover { color: var(--color-brand); }
  }

  .talk-header {
    margin-block-end: var(--space-md);
    padding-block-end: var(--space-md);
    border-block-end: 1px solid var(--border);
  }

  .talk-header__meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
    font-size: 0.875rem;
    color: var(--text-2);
    margin-block-end: 0.75rem;
  }

  .talk-header__title {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    margin: 0 0 1rem;
  }

  .talk-header__actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-block-end: 0.875rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.5rem 1rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.15s;

    &:hover { opacity: 0.85; }
  }

  .btn--primary {
    background: var(--color-brand);
    color: white;
  }

  .btn--secondary {
    background: var(--surface-2);
    color: var(--text-1);
    border: 1px solid var(--border);
  }

  .abstract {
    font-size: 1.0625rem;
    color: var(--text-2);
    line-height: 1.7;
    max-inline-size: 60ch;
    margin-block-end: var(--space-lg);
  }

  .video-section {
    margin-block-end: var(--space-lg);
  }

  .video-wrapper {
    position: relative;
    aspect-ratio: 16/9;
    border-radius: 0.5rem;
    overflow: hidden;
    background: var(--surface-3);

    & iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: 0;
    }
  }
</style>
