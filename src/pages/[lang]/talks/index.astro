---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations, locales, type Locale } from '../../../i18n/utils';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return locales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);

const talks = (await getCollection('talks', ({ id }) => id.startsWith(`${lang}/`)))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const dateFormatter = new Intl.DateTimeFormat(lang, { dateStyle: 'long' });
const slugOf = (id: string) => id.replace(`${lang}/`, '');
---

<BaseLayout lang={lang} title={t.talks.title} description={t.talks.description} canonicalPath="/talks">
  <header class="page-header">
    <h1>{t.talks.title}</h1>
    <p class="page-desc">{t.talks.description}</p>
  </header>

  <ul class="talk-list" role="list">
    {talks.map(talk => (
      <li>
        <a href={`/${lang}/talks/${slugOf(talk.id)}`} class="talk-item">
          <div class="talk-item__side">
            <time datetime={talk.data.date.toISOString()}>
              {dateFormatter.format(talk.data.date)}
            </time>
            {talk.data.videoId && (
              <span class="talk-item__video-badge" aria-label="Video available">▶ video</span>
            )}
          </div>
          <div class="talk-item__body">
            <h2 class="talk-item__title">{talk.data.title}</h2>
            <p class="talk-item__event">{talk.data.event} — {talk.data.location}</p>
            <p class="talk-item__desc">{talk.data.description}</p>
            {talk.data.tags.length > 0 && (
              <ul class="tag-list" role="list">
                {talk.data.tags.map(tag => <li class="tag">{tag}</li>)}
              </ul>
            )}
          </div>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .page-header {
    margin-block-end: var(--size-8);
    padding-block-end: var(--size-5);
    border-block-end: 1px solid var(--border);
  }

  .page-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin: 0 0 0.5rem;
  }

  .page-desc {
    color: var(--text-2);
    margin: 0;
  }

  .talk-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .talk-item {
    display: grid;
    grid-template-columns: 10rem 1fr;
    gap: 1.5rem;
    padding-block: 1.25rem;
    border-block-end: 1px solid var(--border);
    text-decoration: none;
    color: inherit;

    &:last-child { border-block-end: none; }
    &:hover .talk-item__title { color: var(--color-brand); }

    @media (width < 560px) {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
  }

  .talk-item__side {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--text-2);
    padding-block-start: 0.25rem;
  }

  .talk-item__video-badge {
    font-size: 0.75rem;
    color: var(--color-brand);
    border: 1px solid var(--color-brand);
    border-radius: 999px;
    padding: 1px 0.5rem;
    width: fit-content;
  }

  .talk-item__title {
    font-size: 1.125rem;
    margin: 0 0 0.25rem;
    transition: color 0.15s;
  }

  .talk-item__event {
    font-size: 0.875rem;
    color: var(--text-2);
    margin: 0 0 0.375rem;
  }

  .talk-item__desc {
    font-size: 0.9375rem;
    color: var(--text-2);
    margin: 0 0 0.625rem;
    max-inline-size: 55ch;
  }
</style>
