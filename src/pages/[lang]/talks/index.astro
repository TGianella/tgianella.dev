---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations, locales, type Locale } from '../../../i18n/utils';
import { getCollection } from 'astro:content';
import TalkCard from '../../../components/TalkCard.astro';

export function getStaticPaths() {
  return locales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);

const now = new Date();
const isUpcoming = (events: { date: Date }[]) => events.every(e => e.date > now);

const talks = (await getCollection('talks', ({ id, data }) =>
  id.startsWith(`${lang}/`) && data.events.length > 0
))
  .sort((a, b) => {
    // Upcoming talks first, then past talks sorted by most recent debut
    const aUp = isUpcoming(a.data.events);
    const bUp = isUpcoming(b.data.events);
    if (aUp !== bUp) return aUp ? -1 : 1;
    const aMin = Math.min(...a.data.events.map(e => e.date.valueOf()));
    const bMin = Math.min(...b.data.events.map(e => e.date.valueOf()));
    return bMin - aMin;
  });

const slugOf = (id: string) => id.replace(`${lang}/`, '');
---

<BaseLayout lang={lang} title={t.talks.title} description={t.talks.description} canonicalPath="/talks">
  <header class="page-header">
    <h1>{t.talks.title}</h1>
    <p class="page-desc">{t.talks.description}</p>
  </header>

  <ul class="talk-list" role="list">
    {talks.map(talk => (
      <li>
        <TalkCard talk={talk.data} lang={lang} slug={slugOf(talk.id)} />
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .page-header {
    margin-block-end: var(--size-8);
    padding-block-end: var(--size-5);
    border-block-end: var(--border-size-1) solid var(--border);
  }

  .page-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin: 0 0 var(--size-2);
  }

  .page-desc {
    color: var(--text-2);
    margin: 0;
  }

  .talk-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
</style>
