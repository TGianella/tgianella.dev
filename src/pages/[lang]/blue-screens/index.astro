---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import MainContent from "../../../layouts/MainContent.astro";
import PageHeader from "../../../components/PageHeader.astro";
import {
  useTranslations,
  getLocaleStaticPaths,
  getDateFormatter,
  slugOf,
  type Locale,
} from "../../../i18n/utils";
import { sortByDate, thumbnailUrl } from "../../../content/utils";
import { getCollection } from "astro:content";

export const getStaticPaths = getLocaleStaticPaths;

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);

const photos = sortByDate(
  await getCollection("gallery", ({ id }) => id.startsWith(`${lang}/`)),
);

const dateFormatter = getDateFormatter(lang);
---

<BaseLayout
  lang={lang}
  title={t.gallery.title}
  description={t.gallery.description}
  canonicalPath="/blue-screens"
>
  <MainContent>
    <PageHeader title={t.gallery.title} description={t.gallery.description} />

    <ul class="photo-grid">
      {
        photos.map((photo) => (
          <li>
            <a
              href={`/${lang}/blue-screens/${slugOf(photo.id, lang)}`}
              class="photo-card"
            >
              <img
                src={thumbnailUrl(photo.data.src)}
                alt={photo.data.alt}
                width={400}
                height={400}
                class="photo-card__img"
                loading="lazy"
                decoding="async"
              />
              {(photo.data.location || photo.data.date) && (
                <div class="photo-card__overlay">
                  <span class="photo-card__meta">
                    {photo.data.location && <span>{photo.data.location}</span>}
                    {photo.data.date && (
                      <span>{dateFormatter.format(photo.data.date)}</span>
                    )}
                  </span>
                </div>
              )}
            </a>
          </li>
        ))
      }
    </ul>
  </MainContent>
</BaseLayout>

<style>
  .photo-grid {
    --photo-min: min(160px, calc((100% - 2 * var(--size-2)) / 3));

    display: grid;
    gap: var(--size-2);
    grid-template-columns: repeat(
      auto-fill,
      [photo-start] minmax(var(--photo-min), 1fr) [photo-end]
    );
  }

  .photo-card {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: var(--radius-2);
    aspect-ratio: 1;
    background: linear-gradient(
      90deg,
      var(--surface-2) 25%,
      var(--surface-3) 50%,
      var(--surface-2) 75%
    );
    background-size: 200% 100%;
    box-shadow: var(--shadow-3);

    @media (prefers-reduced-motion: no-preference) {
      animation: photo-shimmer 1.5s infinite;
    }
  }

  .photo-card:focus-visible {
    outline: var(--border-size-2) solid var(--color-brand);
    outline-offset: var(--border-size-2);
  }

  .photo-card:has(.photo-card__img.loaded) {
    animation: none;
    background: var(--surface-3);
  }

  .photo-card__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;

    @media (prefers-reduced-motion: no-preference) {
      transition:
        opacity 0.3s ease,
        transform 0.3s ease;
    }
  }

  .photo-card__img.loaded {
    opacity: 1;
  }

  .photo-card__overlay {
    position: absolute;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--size-3);
    background: linear-gradient(
      to top,
      rgb(0 0 0 / 70%) 0%,
      rgb(0 0 0 / 20%) 50%,
      transparent 100%
    );
    gap: 0.2em;
    inset: 0;
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .photo-card__meta {
    display: flex;
    flex-wrap: wrap;
    color: white;
    font-size: var(--font-size-0);
    gap: 0.1em 0.5em;
    opacity: 0.75;
  }

  .photo-card:focus-visible .photo-card__img {
    transform: scale(1.05);
  }

  .photo-card:focus-visible .photo-card__overlay {
    opacity: 1;
  }

  @media (hover: hover) {
    .photo-card:hover .photo-card__img {
      transform: scale(1.05);
    }

    .photo-card:hover .photo-card__overlay {
      opacity: 1;
    }
  }
</style>

<script>
  function initSkeletons() {
    document
      .querySelectorAll<HTMLImageElement>(".photo-card__img")
      .forEach((img) => {
        if (img.complete) {
          img.classList.add("loaded");
        } else {
          img.addEventListener("load", () => img.classList.add("loaded"), {
            once: true,
          });
        }
      });
  }

  document.addEventListener("astro:page-load", initSkeletons);
</script>
