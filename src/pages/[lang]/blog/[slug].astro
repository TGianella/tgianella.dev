---
import { getImage } from "astro:assets";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PersonCard from "../../../components/PersonCard.astro";
import { useTranslations, locales, type Locale } from "../../../i18n/utils";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.flatMap((post) => {
    const [lang, ...slugParts] = post.id.split("/");
    if (!locales.includes(lang as Locale)) return [];
    return [
      {
        params: { lang, slug: slugParts.join("/") },
        props: { post },
      },
    ];
  });
}

const { lang, slug } = Astro.params as { lang: Locale; slug: string };
const { post } = Astro.props;
const t = useTranslations(lang);
const { Content } = await render(post);

const dateFormatter = new Intl.DateTimeFormat(lang, { dateStyle: "long" });
const ogImage = post.data.thumbnail
  ? (await getImage({ src: post.data.thumbnail })).src
  : undefined;
const wordCount = post.body?.split(/\s+/).length ?? 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 300));
---

<BaseLayout
  lang={lang}
  title={post.data.title}
  description={post.data.description}
  canonicalPath={`/blog/${slug}`}
  ogImage={ogImage}
>
  <article
    data-copy-link={t.prose.copyLink}
    data-link-copied={t.prose.linkCopied}
  >
    <a href={`/${lang}/blog`} class="back-link">{t.blog.backToList}</a>

    <header class="post-header">
      <div class="post-header__meta">
        <span class="post-header__meta-item">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5"
            ></path>
          </svg>
          <time datetime={post.data.pubDate.toISOString()}
            >{dateFormatter.format(post.data.pubDate)}</time
          >
        </span>
        <span class="post-header__meta-item">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"></path>
          </svg>
          {t.blog.readingTime(readingTime)}
        </span>
      </div>

      <h1 class="post-header__title">{post.data.title}</h1>
      <p class="post-header__desc">{post.data.description}</p>

      {
        post.data.tags.length > 0 && (
          <ul class="tag-list" aria-label={t.blog.tags}>
            {post.data.tags.map((tag) => (
              <li class="tag">{tag}</li>
            ))}
          </ul>
        )
      }

      {
        post.data.updatedDate && (
          <p class="post-header__updated">
            {t.blog.updatedOn} {dateFormatter.format(post.data.updatedDate)}
          </p>
        )
      }
    </header>

    <div class="post-body">
      {
        post.data.coAuthors.length > 0 && (
          <aside class="coauthors-sidebar">
            <p class="coauthors-sidebar__label">{t.blog.writtenWith}</p>
            <div class="coauthors-sidebar__list">
              {post.data.coAuthors.map((a) => (
                <PersonCard name={a.name} picture={a.picture} url={a.url} />
              ))}
            </div>
          </aside>
        )
      }

      <div class="prose">
        {
          post.data.firstPublishedIn && (
            <p class="origin-notice">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <circle cx="12" cy="12" r="10" />
                <line x1="12" y1="16" x2="12" y2="12" />
                <line x1="12" y1="8" x2="12.01" y2="8" />
              </svg>
              <span>
                {t.blog.firstPublishedIn}{" "}
                {post.data.firstPublishedIn.url ? (
                  <a
                    href={post.data.firstPublishedIn.url}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {post.data.firstPublishedIn.name}
                  </a>
                ) : (
                  post.data.firstPublishedIn.name
                )}
              </span>
            </p>
          )
        }
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>

<dialog class="lbx" aria-label="Image preview">
  <button class="lbx__close" aria-label="Close">✕</button>
  <img class="lbx__img" src="" alt="" />
</dialog>

<script>
  import "../../../scripts/heading-anchors";
  import "../../../scripts/blog-scroll";
</script>

<script>
  let lbxController: AbortController | null = null;

  document.addEventListener("astro:page-load", () => {
    lbxController?.abort();
    lbxController = new AbortController();
    const { signal } = lbxController;

    const dialog = document.querySelector<HTMLDialogElement>(".lbx");
    if (!dialog) return;

    const lbxImg = dialog.querySelector<HTMLImageElement>(".lbx__img");
    const closeBtn = dialog.querySelector<HTMLButtonElement>(".lbx__close");
    if (!lbxImg || !closeBtn) return;

    document.querySelectorAll<HTMLImageElement>(".prose img").forEach((img) => {
      img.tabIndex = 0;
      const open = () => {
        lbxImg.src = img.src;
        lbxImg.alt = img.alt;
        dialog.showModal();
      };
      img.addEventListener("click", open, { signal });
      img.addEventListener(
        "keydown",
        (e) => {
          if (e.key === "Enter" || e.key === " ") {
            e.preventDefault();
            open();
          }
        },
        { signal },
      );
    });

    closeBtn.addEventListener("click", () => dialog.close(), { signal });
    dialog.addEventListener(
      "click",
      (e) => {
        if (e.target === dialog) dialog.close();
      },
      { signal },
    );
  });
</script>

<style>
  article {
    container-type: inline-size;
  }

  .back-link {
    display: inline-block;
    color: var(--text-2);
    font-size: var(--font-size-1);
    margin-block-end: var(--size-5);
    text-decoration: none;
    transition: color 0.15s;

    &:hover,
    &:focus-visible {
      color: var(--color-brand);
    }
  }

  .post-header {
    border-block-end: var(--border-size-1) solid var(--border);
    margin-block-end: var(--size-5);
    padding-block-end: var(--size-5);
  }

  .post-header__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    color: var(--text-2);
    font-size: var(--font-size-1);
    gap: 0.9em;
    margin-block-end: 0.75rem;
  }

  .post-header__meta-item {
    display: flex;
    align-items: center;
    gap: 0.3em;

    & svg {
      width: 1em;
      height: 1em;
      flex-shrink: 0;
      opacity: 0.7;
    }
  }

  .post-header__title {
    margin: 0 0 0.75rem;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
  }

  .post-header__desc {
    margin: 0 0 0.875rem;
    color: var(--text-2);
    font-size: var(--font-size-2);
    max-inline-size: 55ch;
  }

  .post-header__updated {
    margin: 0.75rem 0 0;
    color: var(--text-2);
    font-size: var(--font-size-0);
    font-style: italic;
  }

  .post-body {
    display: grid;
    align-items: start;
    gap: var(--size-4) var(--size-8);
    grid-template-columns: 1fr;
  }

  @media (width >= 48rem) {
    .post-body {
      grid-template-columns: 1fr auto;
    }

    .prose {
      order: -1;
    }
  }

  .coauthors-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--size-3);
  }

  .coauthors-sidebar__list {
    display: flex;
    flex-flow: row wrap;
    gap: var(--size-3);
  }

  @media (width >= 48rem) {
    .coauthors-sidebar__list {
      flex-direction: column;

      & :global(.person-card) {
        width: 100%;
      }
    }
  }

  .coauthors-sidebar__label {
    margin: 0;
    color: var(--text-2);
    font-size: var(--font-size-1);
    font-weight: var(--font-weight-6);
  }

  .origin-notice {
    display: flex;
    align-items: center;
    padding: var(--size-3) var(--size-4);
    border-radius: var(--radius-2);
    margin: 0;
    background: var(--surface-2);
    color: var(--text-2);
    font-size: var(--font-size-1);
    gap: var(--size-4);

    & svg {
      flex-shrink: 0;
    }
  }

  :global(.prose img) {
    cursor: zoom-in;

    &:focus-visible {
      outline: 2px solid var(--color-brand);
      outline-offset: 3px;
    }
  }

  /* ── Lightbox ──────────────────────────────── */
  .lbx {
    position: fixed;
    display: grid;
    padding: var(--size-4);
    border: none;
    background: transparent;
    block-size: 100%;
    inline-size: 100%;
    inset: 0;
    max-block-size: 100%;
    max-inline-size: 100%;
    place-items: center;
  }

  .lbx:not([open]) {
    display: none;
  }

  .lbx::backdrop {
    animation: lbx-backdrop-in 0.15s ease;
    background: oklch(0% 0 0deg / 88%);
  }

  @keyframes lbx-backdrop-in {
    from {
      opacity: 0;
    }

    to {
      opacity: 1;
    }
  }

  .lbx__img {
    display: block;
    border-radius: var(--radius-2);
    animation: lbx-img-in 0.2s ease;
    max-block-size: 85dvh;
    max-inline-size: min(90vw, 960px);
    object-fit: contain;
  }

  @keyframes lbx-img-in {
    from {
      opacity: 0;
      scale: 0.97;
    }

    to {
      opacity: 1;
      scale: 1;
    }
  }

  .lbx__close {
    position: absolute;
    display: grid;
    border: 1px solid oklch(100% 0 0deg / 25%);
    border-radius: var(--radius-round);
    background: oklch(100% 0 0deg / 15%);
    block-size: 2.25rem;
    color: white;
    cursor: pointer;
    font-size: var(--font-size-2);
    inline-size: 2.25rem;
    inset-block-start: var(--size-4);
    inset-inline-end: var(--size-4);
    line-height: 1;
    place-items: center;
    transition: background 0.15s;

    &:hover,
    &:focus-visible {
      background: oklch(100% 0 0deg / 28%);
    }
  }
</style>
