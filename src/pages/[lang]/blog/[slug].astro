---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations, locales, type Locale } from '../../../i18n/utils';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.flatMap(post => {
    const [lang, ...slugParts] = post.id.split('/');
    if (!locales.includes(lang as Locale)) return [];
    return [{
      params: { lang, slug: slugParts.join('/') },
      props: { post },
    }];
  });
}

const { lang, slug } = Astro.params as { lang: Locale; slug: string };
const { post } = Astro.props;
const t = useTranslations(lang);
const { Content } = await render(post);

const dateFormatter = new Intl.DateTimeFormat(lang, { dateStyle: 'long' });
const wordCount = post.body?.split(/\s+/).length ?? 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));
---

<BaseLayout
  lang={lang}
  title={post.data.title}
  description={post.data.description}
  canonicalPath={`/blog/${slug}`}
  ogImage={post.data.cover}
>
  <article>
    <a href={`/${lang}/blog`} class="back-link">{t.blog.backToList}</a>

    <header class="post-header">
      <div class="post-header__meta">
        <time datetime={post.data.pubDate.toISOString()}>
          {t.blog.publishedOn} {dateFormatter.format(post.data.pubDate)}
        </time>
        <span>·</span>
        <span>{t.blog.readingTime(readingTime)}</span>
      </div>

      <h1 class="post-header__title">{post.data.title}</h1>
      <p class="post-header__desc">{post.data.description}</p>

      {post.data.tags.length > 0 && (
        <ul class="tag-list" role="list" aria-label={t.blog.tags}>
          {post.data.tags.map(tag => <li class="tag">{tag}</li>)}
        </ul>
      )}

      {post.data.updatedDate && (
        <p class="post-header__updated">
          {t.blog.updatedOn} {dateFormatter.format(post.data.updatedDate)}
        </p>
      )}
    </header>

    {post.data.cover && (
      <img src={post.data.cover} alt={post.data.coverAlt ?? post.data.title} class="post-cover" loading="eager" />
    )}

    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--text-2);
    text-decoration: none;
    margin-block-end: var(--space-md);
    transition: color 0.15s;

    &:hover { color: var(--color-brand); }
  }

  .post-header {
    margin-block-end: var(--space-md);
    padding-block-end: var(--space-md);
    border-block-end: 1px solid var(--border);
  }

  .post-header__meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
    font-size: 0.875rem;
    color: var(--text-2);
    margin-block-end: 0.75rem;
  }

  .post-header__title {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    margin: 0 0 0.75rem;
  }

  .post-header__desc {
    font-size: 1.0625rem;
    color: var(--text-2);
    margin: 0 0 0.875rem;
    max-inline-size: 55ch;
  }

  .post-header__updated {
    font-size: 0.8125rem;
    color: var(--text-2);
    margin: 0.75rem 0 0;
    font-style: italic;
  }

  .post-cover {
    inline-size: 100%;
    max-block-size: 420px;
    object-fit: cover;
    border-radius: 0.5rem;
    margin-block-end: var(--space-md);
  }
</style>
