---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations, locales, type Locale } from '../../../i18n/utils';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return locales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);

const posts = (await getCollection('blog', ({ id }) => id.startsWith(`${lang}/`)))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const dateFormatter = new Intl.DateTimeFormat(lang, { dateStyle: 'long' });
const slugOf = (id: string) => id.replace(`${lang}/`, '');
---

<BaseLayout lang={lang} title={t.blog.title} description={t.blog.description} canonicalPath="/blog">
  <header class="page-header">
    <h1>{t.blog.title}</h1>
    <p class="page-desc">{t.blog.description}</p>
  </header>

  <ul class="post-list" role="list">
    {posts.map(post => (
      <li>
        <a href={`/${lang}/blog/${slugOf(post.id)}`} class="post-item">
          <div class="post-item__meta">
            <time datetime={post.data.pubDate.toISOString()}>
              {dateFormatter.format(post.data.pubDate)}
            </time>
            {post.data.tags.length > 0 && (
              <ul class="tag-list" role="list" aria-label={t.blog.tags}>
                {post.data.tags.map(tag => <li class="tag">{tag}</li>)}
              </ul>
            )}
          </div>
          <h2 class="post-item__title">{post.data.title}</h2>
          <p class="post-item__desc">{post.data.description}</p>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .page-header {
    margin-block-end: var(--size-8);
    padding-block-end: var(--size-5);
    border-block-end: 1px solid var(--border);
  }

  .page-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin: 0 0 0.5rem;
  }

  .page-desc {
    color: var(--text-2);
    margin: 0;
  }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-item {
    display: grid;
    gap: 0.375rem;
    padding-block: 1.25rem;
    border-block-end: 1px solid var(--border);
    text-decoration: none;
    color: inherit;

    &:last-child { border-block-end: none; }
    &:hover .post-item__title { color: var(--color-brand); }
  }

  .post-item__meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    font-size: 0.8125rem;
    color: var(--text-2);
  }

  .post-item__title {
    font-size: 1.125rem;
    margin: 0;
    transition: color 0.15s;
  }

  .post-item__desc {
    color: var(--text-2);
    margin: 0;
    font-size: 0.9375rem;
    max-inline-size: 60ch;
  }
</style>
