---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import { useTranslations, getLocaleStaticPaths, slugOf, type Locale } from '../../../i18n/utils';
import { getCollection } from 'astro:content';

export const getStaticPaths = getLocaleStaticPaths;

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);

const posts = (await getCollection('blog', ({ id }) => id.startsWith(`${lang}/`)))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const dateFormatter = new Intl.DateTimeFormat(lang, { dateStyle: 'long' });
---

<BaseLayout lang={lang} title={t.blog.title} description={t.blog.description} canonicalPath="/blog">
  <PageHeader title={t.blog.title} description={t.blog.description} />

  <ul class="post-list" role="list">
    {posts.map(post => (
      <li>
        <a href={`/${lang}/blog/${slugOf(post.id, lang)}`} class="post-item">
          <div class="post-item__meta">
            <time datetime={post.data.pubDate.toISOString()}>
              {dateFormatter.format(post.data.pubDate)}
            </time>
            {post.data.tags.length > 0 && (
              <ul class="tag-list" role="list" aria-label={t.blog.tags}>
                {post.data.tags.map(tag => <li class="tag">{tag}</li>)}
              </ul>
            )}
          </div>
          <h2 class="post-item__title">{post.data.title}</h2>
          <p class="post-item__desc">{post.data.description}</p>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-item {
    display: grid;
    gap: 0.375rem;
    padding-block: var(--size-4);
    border-block-end: var(--border-size-1) solid var(--border);
    text-decoration: none;
    color: inherit;

    &:last-child { border-block-end: none; }
    &:hover .post-item__title { color: var(--color-brand); }
  }

  .post-item__meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    font-size: var(--font-size-0);
    color: var(--text-2);
  }

  .post-item__title {
    font-size: var(--font-size-2);
    margin: 0;
    transition: color 0.15s;
  }

  .post-item__desc {
    color: var(--text-2);
    margin: 0;
    font-size: var(--font-size-1);
    max-inline-size: 60ch;
  }
</style>
