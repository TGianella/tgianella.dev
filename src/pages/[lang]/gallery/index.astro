---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations, locales, type Locale } from '../../../i18n/utils';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return locales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);

const albums = (await getCollection('gallery', ({ id }) => id.startsWith(`${lang}/`)))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const dateFormatter = new Intl.DateTimeFormat(lang, { dateStyle: 'long' });
const slugOf = (id: string) => id.replace(`${lang}/`, '');
---

<BaseLayout
  lang={lang}
  title={t.gallery.title}
  description={t.gallery.description}
  canonicalPath="/gallery"
>
  <header class="page-header animate-on-scroll">
    <h1 class="page-header__title">{t.gallery.title}</h1>
    <p class="page-header__desc">{t.gallery.description}</p>
  </header>

  <ul class="album-grid" role="list">
    {albums.map(album => (
      <li class="animate-on-scroll">
        <a href={`/${lang}/gallery/${slugOf(album.id)}`} class="album-card">
          <div class="album-card__img-wrap">
            <img
              src={album.data.coverImage}
              alt={album.data.coverImageAlt}
              class="album-card__img"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="album-card__info">
            <h2 class="album-card__title">{album.data.title}</h2>
            <p class="album-card__meta">
              <time datetime={album.data.date.toISOString()}>
                {dateFormatter.format(album.data.date)}
              </time>
              <span aria-hidden="true">·</span>
              <span>{t.gallery.photos(album.data.photos.length)}</span>
            </p>
            <p class="album-card__desc">{album.data.description}</p>
          </div>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .page-header {
    padding-block-end: var(--size-8);
    border-block-end: 1px solid color-mix(in oklch, var(--text-1) 8%, transparent);
    margin-block-end: var(--size-8);
  }

  .page-header__title {
    font-size: var(--font-size-6);
    margin: 0 0 var(--size-2);
  }

  .page-header__desc {
    color: var(--text-2);
    margin: 0;
  }

  .album-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--size-6);
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
  }

  .album-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border-radius: var(--radius-3);
    overflow: hidden;
    border: 1px solid color-mix(in oklch, var(--text-1) 8%, transparent);
    transition: translate 0.2s, box-shadow 0.2s;

    &:hover {
      translate: 0 -4px;
      box-shadow: var(--shadow-4);
    }

    &:hover .album-card__img {
      transform: scale(1.04);
    }
  }

  .album-card__img-wrap {
    aspect-ratio: 4/3;
    overflow: hidden;
    background: var(--surface-3);
  }

  .album-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .album-card__info {
    padding: var(--size-4);
    display: flex;
    flex-direction: column;
    gap: var(--size-1);
  }

  .album-card__title {
    font-size: var(--font-size-2);
    margin: 0;
  }

  .album-card__meta {
    font-size: var(--font-size-0);
    color: var(--text-2);
    margin: 0;
    display: flex;
    gap: var(--size-2);
    align-items: center;
  }

  .album-card__desc {
    font-size: var(--font-size-0);
    color: var(--text-2);
    margin: 0;
  }
</style>
