---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations, locales, type Locale } from '../../../i18n/utils';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return locales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const t = useTranslations(lang);

const albums = (await getCollection('gallery', ({ id }) => id.startsWith(`${lang}/`)))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const dateFormatter = new Intl.DateTimeFormat(lang, { dateStyle: 'long' });
const slugOf = (id: string) => id.replace(`${lang}/`, '');
---

<BaseLayout lang={lang} title={t.gallery.title} description={t.gallery.description} canonicalPath="/gallery">
  <header class="page-header">
    <h1>{t.gallery.title}</h1>
    <p class="page-desc">{t.gallery.description}</p>
  </header>

  <ul class="album-grid" role="list">
    {albums.map(album => (
      <li>
        <a href={`/${lang}/gallery/${slugOf(album.id)}`} class="album-card">
          <div class="album-card__img-wrap">
            <img
              src={album.data.coverImage}
              alt={album.data.coverImageAlt}
              class="album-card__img"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="album-card__info">
            <h2 class="album-card__title">{album.data.title}</h2>
            <p class="album-card__meta">
              <time datetime={album.data.date.toISOString()}>
                {dateFormatter.format(album.data.date)}
              </time>
              <span aria-hidden="true">·</span>
              <span>{t.gallery.photos(album.data.photos.length)}</span>
            </p>
            <p class="album-card__desc">{album.data.description}</p>
          </div>
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .page-header {
    margin-block-end: var(--space-lg);
    padding-block-end: var(--space-md);
    border-block-end: 1px solid var(--border);
  }

  .page-header h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin: 0 0 0.5rem;
  }

  .page-desc {
    color: var(--text-2);
    margin: 0;
  }

  .album-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 300px), 1fr));
  }

  .album-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    overflow: hidden;
    transition: border-color 0.15s;

    &:hover {
      border-color: var(--color-brand);
    }

    &:hover .album-card__img {
      transform: scale(1.03);
    }
  }

  .album-card__img-wrap {
    aspect-ratio: 4/3;
    overflow: hidden;
    background: var(--surface-3);
  }

  .album-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .album-card__info {
    padding: 0.875rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .album-card__title {
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
  }

  .album-card__meta {
    font-size: 0.8125rem;
    color: var(--text-2);
    margin: 0;
    display: flex;
    gap: 0.375rem;
    align-items: center;
  }

  .album-card__desc {
    font-size: 0.875rem;
    color: var(--text-2);
    margin: 0;
  }
</style>
