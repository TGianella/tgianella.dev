---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GalleryLightbox from '../../../components/GalleryLightbox';
import { useTranslations, locales, type Locale } from '../../../i18n/utils';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const albums = await getCollection('gallery');
  return albums.flatMap(album => {
    const [lang, ...slugParts] = album.id.split('/');
    if (!locales.includes(lang as Locale)) return [];
    return [{
      params: { lang, slug: slugParts.join('/') },
      props: { album },
    }];
  });
}

const { lang, slug } = Astro.params as { lang: Locale; slug: string };
const { album } = Astro.props;
const t = useTranslations(lang);
const { Content } = await render(album);

const dateFormatter = new Intl.DateTimeFormat(lang, { dateStyle: 'long' });
---

<BaseLayout
  lang={lang}
  title={album.data.title}
  description={album.data.description}
  canonicalPath={`/gallery/${slug}`}
  ogImage={album.data.coverImage}
>
  <article>
    <a href={`/${lang}/gallery`} class="back-link">{t.gallery.backToList}</a>

    <header class="album-header">
      <div class="album-header__meta">
        <time datetime={album.data.date.toISOString()}>
          {dateFormatter.format(album.data.date)}
        </time>
        <span aria-hidden="true">·</span>
        <span>{t.gallery.photos(album.data.photos.length)}</span>
      </div>
      <h1 class="album-header__title">{album.data.title}</h1>
    </header>

    <div class="prose album-intro">
      <Content />
    </div>

    <GalleryLightbox
      client:load
      photos={album.data.photos}
      labels={{
        close: t.gallery.close,
        prev: t.gallery.prev,
        next: t.gallery.next,
      }}
    />
  </article>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    font-size: var(--font-size-1);
    color: var(--text-2);
    text-decoration: none;
    margin-block-end: var(--size-5);
    transition: color 0.15s;

    &:hover,
    &:focus-visible { color: var(--color-brand); }
  }

  .album-header {
    margin-block-end: var(--size-3);
  }

  .album-header__meta {
    display: flex;
    gap: 0.375rem;
    align-items: center;
    font-size: var(--font-size-1);
    color: var(--text-2);
    margin-block-end: 0.375rem;
  }

  .album-header__title {
    font-size: clamp(2rem, 4vw, 3rem);
    margin: 0;
  }

  .album-intro {
    margin-block-end: var(--size-5);
    color: var(--text-2);
  }
</style>
