---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import GalleryLightbox from '../../../components/GalleryLightbox';
import { useTranslations, locales, type Locale } from '../../../i18n/utils';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const albums = await getCollection('gallery');
  return albums.flatMap(album => {
    const [lang, ...slugParts] = album.id.split('/');
    if (!locales.includes(lang as Locale)) return [];
    return [{
      params: { lang, slug: slugParts.join('/') },
      props: { album },
    }];
  });
}

const { lang, slug } = Astro.params as { lang: Locale; slug: string };
const { album } = Astro.props;
const t = useTranslations(lang);
const { Content } = await render(album);

const dateFormatter = new Intl.DateTimeFormat(lang, { dateStyle: 'long' });
---

<BaseLayout
  lang={lang}
  title={album.data.title}
  description={album.data.description}
  canonicalPath={`/gallery/${slug}`}
  ogImage={album.data.coverImage}
>
  <article>
    <a href={`/${lang}/gallery`} class="back-link">{t.gallery.backToList}</a>

    <header class="album-header">
      <div class="album-header__meta">
        <time datetime={album.data.date.toISOString()} class="album-header__date">
          {dateFormatter.format(album.data.date)}
        </time>
        <span class="album-header__count">{t.gallery.photos(album.data.photos.length)}</span>
      </div>
      <h1 class="album-header__title">{album.data.title}</h1>
    </header>

    <div class="prose">
      <Content />
    </div>

    <GalleryLightbox
      client:load
      photos={album.data.photos}
      labels={{
        close: t.gallery.close,
        prev: t.gallery.prev,
        next: t.gallery.next,
      }}
    />
  </article>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    font-size: var(--font-size-0);
    color: var(--text-2);
    text-decoration: none;
    margin-block-end: var(--size-6);
    transition: color 0.2s;

    &:hover { color: var(--color-brand); }
  }

  .album-header {
    margin-block-end: var(--size-6);
  }

  .album-header__meta {
    display: flex;
    gap: var(--size-4);
    align-items: center;
    margin-block-end: var(--size-3);
    font-size: var(--font-size-0);
    color: var(--text-2);
  }

  .album-header__title {
    font-size: clamp(var(--font-size-4), 5vw, var(--font-size-6));
    margin: 0;
    line-height: var(--font-lineheight-1);
  }

  .prose {
    max-inline-size: var(--content-max-width);
    margin-block-end: var(--size-8);

    & :global(p) {
      color: var(--text-2);
      line-height: var(--font-lineheight-4);
      margin-block: var(--size-3);
    }
  }
</style>
