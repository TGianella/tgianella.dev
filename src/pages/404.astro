---
import en from "../i18n/en";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>404 — {en.seo.siteName}</title>
    <meta name="robots" content="noindex, nofollow" />

    <link rel="icon" href="/favicon.ico" sizes="16x16 32x32 48x48" />
    <link rel="icon" href="/favicon.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <script is:inline>
      try {
        const theme = localStorage.getItem("theme");
        const expiry = localStorage.getItem("theme-expiry");
        if (theme && expiry && Date.now() < Number(expiry)) {
          document.documentElement.setAttribute("data-theme", theme);
        }
      } catch {
        // localStorage unavailable in some privacy modes; safe to ignore
      }
    </script>
  </head>
  <body>
    <main>
      <p class="code">404</p>
      <h1>{en.notFound.title}</h1>
      <p>{en.notFound.description}</p>
      <a href="/en/">{en.notFound.backHome}</a>
    </main>
  </body>
</html>

<style>
  body {
    display: flex;
    align-items: center;
    justify-content: center;
    min-block-size: 100dvh;
  }

  main {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--size-3);
    padding-inline: var(--page-padding);
    text-align: center;
  }

  .code {
    margin: 0;
    color: var(--color-brand);
    font-size: clamp(5rem, 20vw, 10rem);
    font-weight: var(--font-weight-7);
    line-height: 1;
  }

  h1 {
    margin: 0;
    font-size: var(--font-size-5);
  }

  p {
    margin: 0;
    color: var(--text-2);
  }

  a {
    color: var(--color-brand);
    margin-block-start: var(--size-3);
    text-underline-offset: 3px;

    &:hover {
      text-decoration: none;
    }
  }
</style>
