---
import { useTranslations, getLocalizedPath, type Locale } from '../i18n/utils';

interface Props {
  lang: Locale;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = useTranslations(lang);

const links = [
  { href: getLocalizedPath('/', lang),        label: t.nav.home },
  { href: getLocalizedPath('/blog', lang),    label: t.nav.blog },
  { href: getLocalizedPath('/talks', lang),   label: t.nav.talks },
  { href: getLocalizedPath('/gallery', lang), label: t.nav.gallery },
];

const alternateLang = t.langSwitcher.lang as Locale;
const alternatePath = getLocalizedPath(currentPath.replace(/^\/(en|fr)/, '') || '/', alternateLang);
---

<nav class="nav" aria-label="Main navigation">
  <div class="nav__inner">
    <a href={getLocalizedPath('/', lang)} class="nav__logo">
      {t.seo.siteName}
    </a>

    <!-- Desktop links -->
    <ul class="nav__links" role="list">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={['nav__link', { 'nav__link--active': currentPath === href }]}
            aria-current={currentPath === href ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
      <li>
        <a href={alternatePath} class="nav__link nav__lang" lang={alternateLang} hreflang={alternateLang}>
          {t.langSwitcher.label}
        </a>
      </li>
    </ul>

    <!-- Mobile hamburger (hidden on desktop via CSS) -->
    <button class="nav__hamburger" aria-expanded="false" aria-controls="mobile-menu" aria-label="Open menu">
      <span class="nav__bar"></span>
      <span class="nav__bar"></span>
      <span class="nav__bar"></span>
    </button>
  </div>

  <!-- Mobile menu: starts hidden via the `hidden` attribute -->
  <div id="mobile-menu" class="nav__mobile" hidden>
    <ul role="list">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={['nav__mobile-link', { 'nav__link--active': currentPath === href }]}
            aria-current={currentPath === href ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
      <li>
        <a href={alternatePath} class="nav__mobile-link" lang={alternateLang} hreflang={alternateLang}>
          {t.langSwitcher.label}
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  // astro:page-load fires on initial page load AND after every View Transition.
  // Do NOT call initNav() directly — that would double-register listeners on first load.
  document.addEventListener('astro:page-load', () => {
    const btn = document.querySelector<HTMLButtonElement>('.nav__hamburger');
    const menu = document.querySelector<HTMLElement>('#mobile-menu');
    if (!btn || !menu) return;

    // Ensure menu starts closed after each navigation
    menu.hidden = true;
    btn.setAttribute('aria-expanded', 'false');

    function openMenu() {
      menu!.hidden = false;
      btn!.setAttribute('aria-expanded', 'true');
      btn!.setAttribute('aria-label', 'Close menu');
    }

    function closeMenu() {
      menu!.hidden = true;
      btn!.setAttribute('aria-expanded', 'false');
      btn!.setAttribute('aria-label', 'Open menu');
    }

    btn.addEventListener('click', () => {
      if (menu.hidden) {
        openMenu();
      } else {
        closeMenu();
      }
    });

    // Close when a nav link is clicked
    menu.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', closeMenu);
    });

    // Close on Escape
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && !menu.hidden) {
        closeMenu();
        btn.focus();
      }
    });
  });
</script>

<style>
  /* Ensure `hidden` attribute always works regardless of CSS resets */
  [hidden] {
    display: none !important;
  }

  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--surface-1);
    border-block-end: 1px solid var(--border);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    max-inline-size: var(--layout-width);
    margin-inline: auto;
    padding-inline: var(--page-padding);
    block-size: var(--nav-height);
  }

  .nav__logo {
    font-weight: 700;
    text-decoration: none;
    color: var(--text-1);
    margin-inline-end: auto;
    font-size: 1rem;
  }

  /* ── Desktop links ─────────────────────────────────── */
  .nav__links {
    display: flex;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: center;
  }

  .nav__link {
    text-decoration: none;
    color: var(--text-2);
    font-size: 0.875rem;
    padding: 0.375rem 0.625rem;
    border-radius: 0.375rem;
    transition: color 0.15s, background 0.15s;
  }

  .nav__link:hover {
    color: var(--text-1);
    background: var(--surface-2);
  }

  .nav__link--active {
    color: var(--text-1);
    font-weight: 600;
  }

  .nav__lang {
    margin-inline-start: 0.25rem;
    border: 1px solid var(--border);
  }

  /* ── Hamburger (hidden on desktop) ─────────────────── */
  .nav__hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 0.375rem;
    color: var(--text-1);
  }

  .nav__hamburger:hover {
    background: var(--surface-2);
  }

  .nav__bar {
    display: block;
    width: 20px;
    height: 2px;
    background: currentColor;
    border-radius: 1px;
    transition: transform 0.2s, opacity 0.2s;
  }

  .nav__hamburger[aria-expanded="true"] .nav__bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav__hamburger[aria-expanded="true"] .nav__bar:nth-child(2) {
    opacity: 0;
  }
  .nav__hamburger[aria-expanded="true"] .nav__bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ── Mobile menu (absolutely positioned, no layout shift) */
  .nav__mobile {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--surface-1);
    border-block-end: 1px solid var(--border);
    box-shadow: 0 4px 8px -2px color-mix(in oklch, black 12%, transparent);
  }

  .nav__mobile ul {
    list-style: none;
    margin: 0;
    padding: 0.5rem var(--page-padding);
    display: flex;
    flex-direction: column;
  }

  .nav__mobile-link {
    display: block;
    padding: 0.75rem 0.5rem;
    text-decoration: none;
    color: var(--text-2);
    font-size: 1rem;
    border-block-end: 1px solid var(--border);
    transition: color 0.15s;
  }

  .nav__mobile ul li:last-child .nav__mobile-link {
    border-block-end: none;
  }

  .nav__mobile-link:hover,
  .nav__mobile-link.nav__link--active {
    color: var(--text-1);
  }

  /* ── Responsive breakpoint ─────────────────────────── */
  @media (width < 640px) {
    .nav__links {
      display: none;
    }

    .nav__hamburger {
      display: flex;
    }
  }
</style>
