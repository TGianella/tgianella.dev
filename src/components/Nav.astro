---
import { useTranslations, getLocalizedPath, type Locale } from "../i18n/utils";

interface Props {
  lang: Locale;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;

const t = useTranslations(lang);
const isHomepage = currentPath === "/" || currentPath === "/fr/";
let cleanCurrentPath = currentPath;

if (currentPath.endsWith("/") && !isHomepage) {
  cleanCurrentPath = currentPath.slice(0, -1);
}

const isCurrentPage = (href: string) => {
  if (href === "/" || href === "/fr/") {
    return isHomepage;
  }

  return cleanCurrentPath.includes(href);
};

const links = [
  { href: getLocalizedPath("/", lang), label: t.nav.home, key: "home" },
  { href: getLocalizedPath("/blog", lang), label: t.nav.blog, key: "blog" },
  { href: getLocalizedPath("/talks", lang), label: t.nav.talks, key: "talks" },
  {
    href: getLocalizedPath("/blue-screens", lang),
    label: t.nav.gallery,
    key: "blue-screens",
  },
];

const alternateLang = t.langSwitcher.lang as Locale;
const alternatePath = getLocalizedPath(cleanCurrentPath, alternateLang);
---

<nav class="nav" aria-label={t.nav.mainNavLabel}>
  <div class="nav__inner">
    <a href={getLocalizedPath("/", lang)} class="nav__logo">
      {t.nav.title}
    </a>

    <ul class="nav__links">
      {
        links.map(({ href, label, key }) => (
          <li>
            <a
              href={href}
              class="nav__link"
              data-vt-name={`nav-${key}`}
              aria-current={isCurrentPage(href) ? "page" : undefined}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>

    <button
      class="theme-toggle"
      aria-label={t.themeSwitcher.toDark}
      data-label-to-light={t.themeSwitcher.toLight}
      data-label-to-dark={t.themeSwitcher.toDark}
    >
      <span class="theme-toggle__icon-wrap">
        <svg
          class="theme-toggle__icon"
          data-theme-icon="light"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <line x1="12" y1="2" x2="12" y2="4"></line>
          <line x1="12" y1="20" x2="12" y2="22"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="2" y1="12" x2="4" y2="12"></line>
          <line x1="20" y1="12" x2="22" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <svg
          class="theme-toggle__icon"
          data-theme-icon="dark"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </span>
    </button>

    <a
      href={alternatePath}
      class="lang-switch"
      lang={alternateLang}
      hreflang={alternateLang}
      aria-label={t.langSwitcher.label}
    >
      {
        (["en", "fr"] as const).map((l) => (
          <span
            class="lang-switch__opt"
            aria-hidden="true"
            data-current={l === lang ? "true" : undefined}
            data-vt-name={l === lang ? "lang-thumb" : undefined}
          >
            {l.toUpperCase()}
          </span>
        ))
      }
    </a>

    <button
      class="nav__hamburger"
      popovertarget="mobile-menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label={t.nav.openMenu}
      data-label-open={t.nav.openMenu}
      data-label-close={t.nav.closeMenu}
    >
      <span class="hamburger__bar"></span>
      <span class="hamburger__bar"></span>
      <span class="hamburger__bar"></span>
    </button>
  </div>

  <div id="mobile-menu" class="nav__mobile" popover="auto">
    <ul>
      {
        links.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class="nav__mobile-link"
              aria-current={isCurrentPage(href) ? "page" : undefined}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<script>
  const WEEK_MS = 7 * 24 * 60 * 60 * 1000;

  function getCurrentTheme(): "light" | "dark" {
    const attr = document.documentElement.getAttribute("data-theme");
    if (attr === "light" || attr === "dark") return attr;
    return window.matchMedia("(prefers-color-scheme: dark)").matches
      ? "dark"
      : "light";
  }

  function setTheme(theme: "light" | "dark") {
    document.documentElement.setAttribute("data-theme", theme);
    try {
      localStorage.setItem("theme", theme);
      localStorage.setItem("theme-expiry", String(Date.now() + WEEK_MS));
    } catch {
      // localStorage unavailable in some privacy modes; theme still applies via data-theme
    }
  }

  function clearStoredTheme() {
    try {
      localStorage.removeItem("theme");
      localStorage.removeItem("theme-expiry");
    } catch {
      // localStorage unavailable in some privacy modes; safe to ignore
    }
  }

  // When the system theme changes, drop the stored preference and follow the system
  window
    .matchMedia("(prefers-color-scheme: dark)")
    .addEventListener("change", () => {
      clearStoredTheme();
      document.documentElement.removeAttribute("data-theme");
      const themeBtn =
        document.querySelector<HTMLButtonElement>(".theme-toggle");
      if (themeBtn) {
        const labelToLight = themeBtn.dataset.labelToLight!;
        const labelToDark = themeBtn.dataset.labelToDark!;
        themeBtn.setAttribute(
          "aria-label",
          getCurrentTheme() === "dark" ? labelToLight : labelToDark,
        );
      }
    });

  document.addEventListener("astro:page-load", () => {
    const langSwitch =
      document.querySelector<HTMLAnchorElement>(".lang-switch");
    if (langSwitch) {
      const base = langSwitch.href.split("?")[0];
      langSwitch.href = location.search ? `${base}${location.search}` : base;
    }

    const themeBtn = document.querySelector<HTMLButtonElement>(".theme-toggle");
    if (themeBtn) {
      const labelToLight = themeBtn.dataset.labelToLight!;
      const labelToDark = themeBtn.dataset.labelToDark!;

      const updateLabel = () => {
        themeBtn.setAttribute(
          "aria-label",
          getCurrentTheme() === "dark" ? labelToLight : labelToDark,
        );
      };
      updateLabel();

      themeBtn.addEventListener("click", () => {
        themeBtn.classList.add("is-switching");
        setTheme(getCurrentTheme() === "dark" ? "light" : "dark");
        updateLabel();
        themeBtn.addEventListener(
          "transitionend",
          () => themeBtn.classList.remove("is-switching"),
          { once: true },
        );
      });
    }

    const menu = document.querySelector<HTMLElement>("#mobile-menu");
    const btn = document.querySelector<HTMLButtonElement>(".nav__hamburger");
    if (!menu || !btn) return;

    menu.addEventListener("toggle", (e) => {
      const open = (e as ToggleEvent).newState === "open";
      btn.setAttribute("aria-expanded", String(open));
      btn.setAttribute(
        "aria-label",
        open ? (btn.dataset.labelClose ?? "") : (btn.dataset.labelOpen ?? ""),
      );
    });
  });
</script>

<style>
  .nav {
    position: sticky;
    z-index: var(--layer-3);
    top: 0;
    background: var(--surface-1);
    border-block-end: var(--border-size-1) solid var(--border);

    @media (prefers-reduced-motion: no-preference) {
      view-transition-name: site-nav;
    }
  }

  .nav__inner {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    block-size: var(--nav-height);
    gap: var(--size-3);
    margin-inline: auto;
    max-inline-size: var(--layout-width);
    padding-inline: var(--page-padding);
  }

  .nav__logo {
    color: var(--text-1);
    font-family: var(--font-transitional);
    font-size: var(--font-size-2);
    font-weight: var(--font-weight-7);
    margin-inline-end: auto;
    text-decoration: none;
  }

  .nav__links {
    display: none;
    align-items: center;
    gap: var(--size-1);
  }

  @media (width >= 700px) {
    .nav__links {
      display: flex;
      flex-wrap: nowrap;
    }
  }

  .nav__link {
    padding: var(--size-1) var(--size-2);
    border-radius: var(--radius-2);
    color: var(--text-2);
    font-size: var(--font-size-1);
    text-decoration: none;
    transition:
      color var(--duration-quick-2),
      background var(--duration-quick-2);
    view-transition-class: text-transition nav-elevated;
    white-space: nowrap;
  }

  @media (hover: hover) {
    .nav__link:hover {
      background: var(--surface-3);
      color: var(--text-1);
    }
  }

  .nav__link:focus-visible {
    background: var(--surface-3);
    color: var(--text-1);
    outline: 2px solid var(--color-brand);
    outline-offset: 2px;
  }

  .nav__link[aria-current="page"] {
    color: var(--text-1);
    font-weight: var(--font-weight-6);
  }

  .theme-toggle {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: center;
    padding: var(--size-2);
    border: none;
    border-radius: var(--radius-round);
    background: none;
    color: var(--text-2);
    cursor: pointer;
    transition:
      color var(--duration-quick-2),
      background var(--duration-quick-2);

    &:focus-visible {
      outline: 2px solid var(--color-brand);
      outline-offset: 2px;
    }

    @media (hover: hover) {
      &:hover {
        background: var(--surface-3);
        color: var(--text-1);
      }
    }
  }

  .theme-toggle__icon-wrap {
    position: relative;
    display: block;
    width: 1.25rem;
    height: 1.25rem;
  }

  .theme-toggle__icon {
    position: absolute;
    width: 1.25rem;
    height: 1.25rem;
    inset: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    .theme-toggle.is-switching .theme-toggle__icon {
      transition:
        opacity var(--duration-quick-2),
        transform var(--duration-quick-2);
    }
  }

  /* Default: sun visible, moon rotated away */
  .theme-toggle__icon[data-theme-icon="light"] {
    opacity: 1;
    transform: none;
  }

  .theme-toggle__icon[data-theme-icon="dark"] {
    opacity: 0;
    transform: rotate(90deg) scale(0.5);
  }

  /* Dark mode: moon visible, sun rotated away */
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"])
      .theme-toggle__icon[data-theme-icon="light"] {
      opacity: 0;
      transform: rotate(-90deg) scale(0.5);
    }

    :root:not([data-theme="light"])
      .theme-toggle__icon[data-theme-icon="dark"] {
      opacity: 1;
      transform: none;
    }
  }

  :root[data-theme="dark"] .theme-toggle__icon[data-theme-icon="light"] {
    opacity: 0;
    transform: rotate(-90deg) scale(0.5);
  }

  :root[data-theme="dark"] .theme-toggle__icon[data-theme-icon="dark"] {
    opacity: 1;
    transform: none;
  }

  :root[data-theme="light"] .theme-toggle__icon[data-theme-icon="dark"] {
    opacity: 0;
    transform: rotate(90deg) scale(0.5);
  }

  .lang-switch {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    padding: 2px;
    border: var(--border-size-1) solid var(--border);
    border-radius: var(--radius-round);
    background: var(--surface-3);
    color: inherit;
    gap: 2px;
    text-decoration: none;

    &:focus-visible {
      outline: 2px solid var(--color-brand);
      outline-offset: 2px;
    }
  }

  .lang-switch__opt {
    padding: 1px var(--size-2);
    border-radius: var(--radius-round);
    color: var(--text-2);
    font-size: var(--font-size-0);
    font-weight: var(--font-weight-6);
    text-decoration: none;
    transition: color var(--duration-quick-2);

    @media (hover: hover) {
      &:hover {
        color: var(--text-1);
      }
    }

    &[data-current="true"] {
      background: var(--surface-1);
      box-shadow: var(--shadow-1);
      color: var(--text-1);
    }
  }

  .nav__hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--size-2);
    border: none;
    border-radius: var(--radius-2);
    background: none;
    color: var(--text-1);
    cursor: pointer;
    gap: var(--size-px-1);
  }

  @media (hover: hover) {
    .nav__hamburger:hover {
      background: var(--surface-2);
    }
  }

  .nav__hamburger:focus-visible {
    background: var(--surface-2);
    outline: 2px solid var(--color-brand);
    outline-offset: 2px;
  }

  @media (width >= 700px) {
    .nav__hamburger {
      display: none;
    }
  }

  .hamburger__bar {
    display: block;
    width: 20px;
    height: var(--border-size-2);
    border-radius: var(--radius-1);
    background: currentcolor;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hamburger__bar {
      transition:
        transform var(--duration-moderate-1),
        opacity var(--duration-moderate-1);
    }
  }

  .nav:has(#mobile-menu:popover-open) .hamburger__bar:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .nav:has(#mobile-menu:popover-open) .hamburger__bar:nth-child(2) {
    opacity: 0;
  }

  .nav:has(#mobile-menu:popover-open) .hamburger__bar:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  .nav__mobile {
    position: fixed;
    top: var(--nav-height);
    right: 0;
    left: 0;
    width: 100%;
    padding: 0;
    border: none;
    margin: 0;
    background: var(--surface-1);
    border-block-end: var(--border-size-1) solid var(--border);
    box-shadow: var(--shadow-2);
    opacity: 0;
    transition:
      opacity var(--duration-moderate-1) ease,
      display var(--duration-moderate-1) allow-discrete,
      overlay var(--duration-moderate-1) allow-discrete;
  }

  .nav__mobile:popover-open {
    opacity: 1;
  }

  @starting-style {
    .nav__mobile:popover-open {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .nav__mobile {
      transform: translateY(-0.5rem);
      transition:
        transform var(--duration-moderate-1) ease,
        opacity var(--duration-moderate-1) ease,
        display var(--duration-moderate-1) allow-discrete,
        overlay var(--duration-moderate-1) allow-discrete;
    }

    .nav__mobile:popover-open {
      transform: translateY(0);
    }

    @starting-style {
      .nav__mobile:popover-open {
        opacity: 0;
        transform: translateY(-0.5rem);
      }
    }
  }

  .nav__mobile ul {
    display: flex;
    flex-direction: column;
    padding: var(--size-2) var(--page-padding);
  }

  .nav__mobile-link {
    display: block;
    padding: var(--size-2) var(--size-2);
    border-block-end: var(--border-size-1) solid var(--border);
    color: var(--text-2);
    font-size: var(--font-size-2);
    text-decoration: none;
    transition: color var(--duration-quick-2);
  }

  .nav__mobile-link[aria-current="page"] {
    color: var(--text-1);
  }

  @media (hover: hover) {
    .nav__mobile-link:hover {
      color: var(--text-1);
    }
  }

  .nav__mobile-link:focus-visible {
    color: var(--text-1);
    outline: 2px solid var(--color-brand);
    outline-offset: -2px;
  }

  .nav__mobile ul li:last-child .nav__mobile-link {
    border-block-end: none;
  }
</style>
