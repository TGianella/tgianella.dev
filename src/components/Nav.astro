---
import { useTranslations, getLocalizedPath, type Locale } from '../i18n/utils';

interface Props {
  lang: Locale;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = useTranslations(lang);

const links = [
  { href: getLocalizedPath('/', lang),        label: t.nav.home,    key: 'home' },
  { href: getLocalizedPath('/blog', lang),    label: t.nav.blog,    key: 'blog' },
  { href: getLocalizedPath('/talks', lang),   label: t.nav.talks,   key: 'talks' },
  { href: getLocalizedPath('/gallery', lang), label: t.nav.gallery, key: 'gallery' },
];

const alternateLang = t.langSwitcher.lang as Locale;
const alternatePath = getLocalizedPath(currentPath.replace(/^\/(en|fr)/, '') || '/', alternateLang);
---

<nav class="nav" aria-label={t.nav.mainNavLabel}>
  <div class="nav__inner">
    <a href={getLocalizedPath('/', lang)} class="nav__logo">
      {t.nav.title}
    </a>

    <ul class="nav__links">
      {links.map(({ href, label, key }) => (
        <li>
          <a
            href={href}
            class="nav__link"
            data-vt-name={`nav-${key}`}
            aria-current={currentPath === href ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <button
      class="theme-toggle"
      aria-label={t.themeSwitcher.toDark}
      data-label-to-light={t.themeSwitcher.toLight}
      data-label-to-dark={t.themeSwitcher.toDark}
    >
      <span class="theme-toggle__icon-wrap">
        <svg class="theme-toggle__icon" data-theme-icon="light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"/>
          <line x1="12" y1="2" x2="12" y2="4"/>
          <line x1="12" y1="20" x2="12" y2="22"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="2" y1="12" x2="4" y2="12"/>
          <line x1="20" y1="12" x2="22" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg class="theme-toggle__icon" data-theme-icon="dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </span>
    </button>

    <a href={alternatePath} class="lang-switch" lang={alternateLang} hreflang={alternateLang} aria-label={t.langSwitcher.label}>
      {(['en', 'fr'] as const).map(l => (
        <span class="lang-switch__opt" aria-hidden="true" data-current={l === lang ? 'true' : undefined} data-vt-name={l === lang ? 'lang-thumb' : undefined}>
          {l.toUpperCase()}
        </span>
      ))}
    </a>

    <button
      class="nav__hamburger"
      popovertarget="mobile-menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label={t.nav.openMenu}
      data-label-open={t.nav.openMenu}
      data-label-close={t.nav.closeMenu}
    >
      <span class="hamburger__bar"></span>
      <span class="hamburger__bar"></span>
      <span class="hamburger__bar"></span>
    </button>
  </div>

  <div id="mobile-menu" class="nav__mobile" popover="auto">
    <ul>
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="nav__mobile-link"
            aria-current={currentPath === href ? 'page' : undefined}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const WEEK_MS = 7 * 24 * 60 * 60 * 1000;

  function getCurrentTheme(): 'light' | 'dark' {
    const attr = document.documentElement.getAttribute('data-theme');
    if (attr === 'light' || attr === 'dark') return attr;
    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  }

  function setTheme(theme: 'light' | 'dark') {
    document.documentElement.setAttribute('data-theme', theme);
    try {
      localStorage.setItem('theme', theme);
      localStorage.setItem('theme-expiry', String(Date.now() + WEEK_MS));
    } catch(e) {}
  }

  function clearStoredTheme() {
    try {
      localStorage.removeItem('theme');
      localStorage.removeItem('theme-expiry');
    } catch(e) {}
  }

  // When the system theme changes, drop the stored preference and follow the system
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
    clearStoredTheme();
    document.documentElement.removeAttribute('data-theme');
    const themeBtn = document.querySelector<HTMLButtonElement>('.theme-toggle');
    if (themeBtn) {
      const labelToLight = themeBtn.dataset.labelToLight!;
      const labelToDark = themeBtn.dataset.labelToDark!;
      themeBtn.setAttribute('aria-label', getCurrentTheme() === 'dark' ? labelToLight : labelToDark);
    }
  });

  document.addEventListener('astro:page-load', () => {
    const themeBtn = document.querySelector<HTMLButtonElement>('.theme-toggle');
    if (themeBtn) {
      const labelToLight = themeBtn.dataset.labelToLight!;
      const labelToDark = themeBtn.dataset.labelToDark!;

      const updateLabel = () => {
        themeBtn.setAttribute('aria-label', getCurrentTheme() === 'dark' ? labelToLight : labelToDark);
      };
      updateLabel();

      themeBtn.addEventListener('click', () => {
        setTheme(getCurrentTheme() === 'dark' ? 'light' : 'dark');
        updateLabel();
      });
    }

    const menu = document.querySelector<HTMLElement>('#mobile-menu');
    const btn = document.querySelector<HTMLButtonElement>('.nav__hamburger');
    if (!menu || !btn) return;

    menu.addEventListener('toggle', (e) => {
      const open = (e as ToggleEvent).newState === 'open';
      btn.setAttribute('aria-expanded', String(open));
      btn.setAttribute('aria-label', open ? (btn.dataset.labelClose ?? '') : (btn.dataset.labelOpen ?? ''));
    });
  });

</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: var(--layer-2);
    background: var(--surface-1);
    border-block-end: var(--border-size-1) solid var(--border);
    view-transition-name: site-nav;
  }

  .nav__inner {
    display: flex;
    align-items: center;
    gap: var(--size-3);
    max-inline-size: var(--layout-width);
    margin-inline: auto;
    padding-inline: var(--page-padding);
    block-size: var(--nav-height);
  }

  .nav__logo {
    font-family: var(--font-transitional);
    font-weight: var(--font-weight-7);
    text-decoration: none;
    color: var(--text-1);
    margin-inline-end: auto;
    font-size: var(--font-size-2);
  }

  .nav__links {
    display: flex;
    gap: var(--size-1);
    list-style: none;
    margin: 0;
    padding: 0;
    align-items: center;
  }

  .nav__link {
    text-decoration: none;
    color: var(--text-2);
    font-size: var(--font-size-1);
    padding: var(--size-1) var(--size-2);
    border-radius: var(--radius-2);
    transition: color 0.15s, background 0.15s;
    view-transition-class: text-transition;
  }

  .nav__link:hover {
    color: var(--text-1);
    background: var(--surface-3);
  }

  .nav__link:focus-visible {
    color: var(--text-1);
    background: var(--surface-3);
    outline: 2px solid var(--color-brand);
    outline-offset: 2px;
  }

  .nav__link[aria-current="page"] {
    color: var(--text-1);
    font-weight: var(--font-weight-6);
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--size-2);
    background: none;
    border: none;
    border-radius: var(--radius-round);
    cursor: pointer;
    color: var(--text-2);
    transition: color 0.15s, background 0.15s;

    &:hover { color: var(--text-1); background: var(--surface-3); }
    &:focus-visible { outline: 2px solid var(--color-brand); outline-offset: 2px; }
  }

  .theme-toggle__icon-wrap {
    position: relative;
    width: 1.25rem;
    height: 1.25rem;
    display: block;
  }

  .theme-toggle__icon {
    position: absolute;
    inset: 0;
    width: 1.25rem;
    height: 1.25rem;
    transition: opacity 0.15s, transform 0.15s;
  }

  /* Default: sun visible, moon rotated away */
  .theme-toggle__icon[data-theme-icon="light"]  { opacity: 1; transform: none; }
  .theme-toggle__icon[data-theme-icon="dark"]   { opacity: 0; transform: rotate(90deg) scale(0.5); }

  /* Dark mode: moon visible, sun rotated away */
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .theme-toggle__icon[data-theme-icon="light"] { opacity: 0; transform: rotate(-90deg) scale(0.5); }
    :root:not([data-theme="light"]) .theme-toggle__icon[data-theme-icon="dark"]  { opacity: 1; transform: none; }
  }
  :root[data-theme="dark"]  .theme-toggle__icon[data-theme-icon="light"] { opacity: 0; transform: rotate(-90deg) scale(0.5); }
  :root[data-theme="dark"]  .theme-toggle__icon[data-theme-icon="dark"]  { opacity: 1; transform: none; }
  :root[data-theme="light"] .theme-toggle__icon[data-theme-icon="dark"]  { opacity: 0; transform: rotate(90deg) scale(0.5); }

  .lang-switch {
    display: flex;
    align-items: center;
    gap: 2px;
    padding: 2px;
    background: var(--surface-3);
    border: var(--border-size-1) solid var(--border);
    border-radius: var(--radius-round);
    text-decoration: none;
    color: inherit;

    &:focus-visible {
      outline: 2px solid var(--color-brand);
      outline-offset: 2px;
    }
  }

  .lang-switch__opt {
    padding: 1px var(--size-2);
    border-radius: var(--radius-round);
    font-size: var(--font-size-0);
    font-weight: var(--font-weight-6);
    text-decoration: none;
    color: var(--text-2);
    transition: color 0.15s;

    &:hover {
      color: var(--text-1);
    }

    &[data-current="true"] {
      background: var(--surface-1);
      color: var(--text-1);
      box-shadow: var(--shadow-1);
    }
  }

  .nav__hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--size-2);
    border-radius: var(--radius-2);
    color: var(--text-1);
  }

  .nav__hamburger:hover {
    background: var(--surface-2);
  }

  .nav__hamburger:focus-visible {
    background: var(--surface-2);
    outline: 2px solid var(--color-brand);
    outline-offset: 2px;
  }

  .hamburger__bar {
    display: block;
    width: 20px;
    height: var(--border-size-2);
    background: currentColor;
    border-radius: var(--radius-1);
    transition: transform 0.2s, opacity 0.2s;
  }

  .nav:has(#mobile-menu:popover-open) .hamburger__bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav:has(#mobile-menu:popover-open) .hamburger__bar:nth-child(2) {
    opacity: 0;
  }
  .nav:has(#mobile-menu:popover-open) .hamburger__bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .nav__mobile {
    border: none;
    padding: 0;
    margin: 0;
    inset: unset;

    position: fixed;
    top: var(--nav-height);
    left: 0;
    right: 0;
    width: 100%;

    background: var(--surface-1);
    border-block-end: var(--border-size-1) solid var(--border);
    box-shadow: var(--shadow-2);

    transform: translateY(-0.5rem);
    opacity: 0;
    transition:
      transform 0.2s ease,
      opacity 0.2s ease,
      display 0.2s allow-discrete,
      overlay 0.2s allow-discrete;
  }

  .nav__mobile:popover-open {
    transform: translateY(0);
    opacity: 1;
  }

  @starting-style {
    .nav__mobile:popover-open {
      transform: translateY(-0.5rem);
      opacity: 0;
    }
  }

  .nav__mobile ul {
    list-style: none;
    margin: 0;
    padding: var(--size-2) var(--page-padding);
    display: flex;
    flex-direction: column;
  }

  .nav__mobile-link {
    display: block;
    padding: var(--size-2) var(--size-2);
    text-decoration: none;
    color: var(--text-2);
    font-size: var(--font-size-2);
    border-block-end: var(--border-size-1) solid var(--border);
    transition: color 0.15s;
  }

  .nav__mobile ul li:last-child .nav__mobile-link {
    border-block-end: none;
  }

  .nav__mobile-link:hover,
  .nav__mobile-link[aria-current="page"] {
    color: var(--text-1);
  }

  .nav__mobile-link:focus-visible {
    color: var(--text-1);
    outline: 2px solid var(--color-brand);
    outline-offset: -2px;
  }

  @media (width < 640px) {
    .nav__links {
      display: none;
    }

    .nav__hamburger {
      display: flex;
    }
  }

</style>
