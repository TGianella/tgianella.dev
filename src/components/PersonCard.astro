---
interface Props {
  name: string;
  picture?: string;
  url?: string;
  label?: string;
}

const { name, picture, url, label } = Astro.props;
const avatar =
  picture ?? `https://picsum.photos/seed/${encodeURIComponent(name)}/96/96`;
const Tag = url ? "a" : "div";
---

<div class="person-card-wrap">
  {label && <span class="person-card__label">{label}</span>}
  <Tag
    class="person-card"
    {...url ? { href: url, target: "_blank", rel: "noopener noreferrer" } : {}}
  >
    <img
      class="person-card__avatar"
      src={avatar}
      alt={name}
      width="96"
      height="96"
    />
    <span class="person-card__name">
      {name.split(" ").map((part) => <span>{part}</span>)}
    </span>
  </Tag>
</div>

<style>
  .person-card-wrap {
    display: flex;
    flex-direction: column;
    align-items: start;
    gap: var(--size-1);
  }

  @media (width >= 36rem) {
    .person-card-wrap {
      flex-direction: row;
      align-items: center;
      gap: var(--size-3);
    }
  }

  .person-card {
    display: inline-flex;
    flex-wrap: nowrap;
    align-items: center;
    padding: var(--size-2) var(--size-3);
    border-radius: var(--radius-2);
    background: var(--surface-2);
    color: inherit;
    gap: var(--size-2);
    text-decoration: none;
    transition: border-color 0.15s;

    @media (hover: hover) {
      &:is(a):hover {
        border-color: var(--color-brand);
      }
    }
  }

  .person-card__avatar {
    width: 3rem;
    height: 3rem;
    flex-shrink: 0;
    border-radius: var(--radius-round);
    object-fit: cover;
  }

  .person-card__label {
    color: var(--text-2);
    font-size: var(--font-size-1);
    white-space: nowrap;
  }

  .person-card__name {
    display: flex;
    flex-direction: column;
    font-size: var(--font-size-1);
    font-weight: var(--font-weight-6);
    line-height: 1.5;
  }
</style>
