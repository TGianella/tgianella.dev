---
interface Props {
  title: string;
  description?: string;
  transitionName?: string;
}

const { title, description, transitionName } = Astro.props;
---

<header class="page-header">
  <h1 data-vt-name={transitionName || undefined}>{title}</h1>
  {description && <p class="page-desc">{description}</p>}
  <slot />
</header>

<style>
  .page-header {
    border-block-end: var(--border-size-1) solid var(--border);
    margin-block-end: var(--size-5);
  }

  .page-header h1 {
    width: fit-content;
    margin: 0 0 var(--size-4);
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    line-height: 1.1;
    view-transition-class: text-transition;
  }

  .page-desc {
    color: var(--text-2);
  }
</style>
