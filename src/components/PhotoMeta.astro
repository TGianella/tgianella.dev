---
import { getDateFormatter, type Locale } from "../i18n/utils";

interface Props {
  date?: Date;
  location?: string;
  lang: Locale;
}

const { date, location, lang } = Astro.props;
const dateFormatter = getDateFormatter(lang);
---

{
  (date || location) && (
    <div class="photo-meta">
      {location && (
        <span class="photo-meta__item">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="1em"
            height="1em"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
            <circle cx="12" cy="10" r="3" />
          </svg>
          {location}
        </span>
      )}
      {date && (
        <time class="photo-meta__item" datetime={date.toISOString()}>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="1em"
            height="1em"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
            <line x1="16" y1="2" x2="16" y2="6" />
            <line x1="8" y1="2" x2="8" y2="6" />
            <line x1="3" y1="10" x2="21" y2="10" />
          </svg>
          {dateFormatter.format(date)}
        </time>
      )}
    </div>
  )
}

<style>
  .photo-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--size-3);
  }

  .photo-meta__item {
    display: flex;
    align-items: center;
    color: var(--text-2);
    font-size: var(--font-size-1);
    gap: 0.375em;
  }

  .photo-meta__item svg {
    flex-shrink: 0;
    opacity: 0.75;
  }
</style>
