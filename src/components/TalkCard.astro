---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { useTranslations, isUpcoming, type Locale } from '../i18n/utils';

interface Props {
  talk: {
    title: string;
    description: string;
    thumbnail?: ImageMetadata;
    tags: string[];
    events: {
      date: Date;
      name: string;
      location: string;
      scope: 'internal' | 'regional' | 'national';
    }[];
  };
  lang: Locale;
  slug: string;
}

const { talk, lang, slug } = Astro.props;
const t = useTranslations(lang);
const dateFormatter = new Intl.DateTimeFormat(lang, { dateStyle: 'long' });

const upcoming = isUpcoming(talk.events);

const earliest = (scope: 'national' | 'regional' | 'internal') =>
  talk.events.filter(e => e.scope === scope).sort((a, b) => a.date.valueOf() - b.date.valueOf())[0];
const debutEvent = earliest('national') ?? earliest('regional') ?? earliest('internal');
const fallbackSrc = `https://picsum.photos/seed/${slug}/320/180`;
---

<a href={`/${lang}/talks/${slug}`} class="talk-card">
  <div class="talk-card__side">
    <div class="talk-card__thumb-wrap">
      {talk.thumbnail
        ? <Image src={talk.thumbnail} alt="" class="talk-card__thumb" />
        : <img src={fallbackSrc} alt="" class="talk-card__thumb" loading="lazy" decoding="async" width="320" height="180" />
      }
      {upcoming && (
        <span class="upcoming-pill talk-card__upcoming-pill">{t.talks.upcoming}</span>
      )}
    </div>
  </div>

  <div class="talk-card__body">
    <div class="talk-card__title-row">
      <h2 class="talk-card__title">{talk.title}</h2>
    </div>
    <p class="talk-card__event">
      <span class="talk-card__event-item">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
        </svg>
        <time datetime={debutEvent.date.toISOString()}>{dateFormatter.format(debutEvent.date)}</time>
      </span>
      <span class="talk-card__event-item">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 0 0 6-6v-1.5m-6 7.5a6 6 0 0 1-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 0 1-3-3V4.5a3 3 0 1 1 6 0v8.25a3 3 0 0 1-3 3Z" />
        </svg>
        {debutEvent.name}
      </span>
      <span class="talk-card__event-item">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
        </svg>
        {debutEvent.location}
      </span>
    </p>
    {talk.events.length > 1 && (
      <p class="talk-card__count">{t.talks.moreEvents(talk.events.length - 1)}</p>
    )}
    <p class="talk-card__desc prose">{talk.description}</p>
    {talk.tags.length > 0 && (
      <ul class="tag-list" role="list">
        {talk.tags.map(tag => <li class="tag">{tag}</li>)}
      </ul>
    )}
  </div>
</a>

<style>
  .talk-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--size-3);
    padding: var(--size-4);
    border-block-end: var(--border-size-1) solid var(--border);
    border-radius: var(--radius-2);
    text-decoration: none;
    color: inherit;

    transition: background 0.15s;

    &:last-of-type { border-block-end: none; }
    &:hover { background: var(--surface-2); }
    &:hover .talk-card__title { color: var(--color-brand); }
  }

  @media (width >= 560px) {
    .talk-card {
      grid-template-columns: minmax(auto, 16rem) 1fr;
      gap: var(--size-5);
      align-items: center;
    }
  }


  .talk-card__thumb-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-2);
    overflow: hidden;
    background: var(--surface-3);
  }

  @media (width >= 560px) {
    .talk-card__thumb-wrap {
      flex: 1;
      min-inline-size: 10rem;
      max-inline-size: 16rem;
      max-block-size: 9rem; /* 16rem × 9/16 — keeps aspect ratio at the cap */
    }
  }

  .talk-card__thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;

    .talk-card:hover & {
      transform: scale(1.04);
    }
  }

  .talk-card__title-row {
    margin: 0 0 var(--size-1);
  }

  .talk-card__upcoming-pill {
    position: absolute;
    top: var(--size-2);
    left: var(--size-2);
    font-size: var(--font-size-1);
    padding: var(--size-1) var(--size-3);
    background: color-mix(in oklch, var(--color-brand) 18%, var(--surface-1));
    backdrop-filter: blur(4px);
  }

  @media (width >= 560px) {
    .talk-card__upcoming-pill {
      font-size: var(--font-size-0);
      padding: 1px var(--size-2);
    }
  }

  .talk-card__title {
    font-size: var(--font-size-2);
    margin: 0;
    transition: color 0.15s;
  }

  .talk-card__event {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.2em 0.9em;
    font-size: var(--font-size-1);
    color: var(--text-2);
    margin: 0 0 0.25rem;
  }

  .talk-card__event-item {
    display: flex;
    align-items: center;
    gap: 0.3em;

    & svg {
      width: 1em;
      height: 1em;
      flex-shrink: 0;
      opacity: 0.7;
    }
  }

  .talk-card__count {
    font-size: var(--font-size-0);
    color: var(--text-2);
    margin: 0 0 0.375rem;
  }

  .talk-card__desc {
    font-size: var(--font-size-1);
    color: var(--text-2);
    margin: 0 0 0.625rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
