---
import { useTranslations, type Locale } from '../i18n/utils';

interface Props {
  talk: {
    title: string;
    description: string;
    thumbnail?: string;
    tags: string[];
    events: {
      date: Date;
      name: string;
      location: string;
      scope: 'internal' | 'regional' | 'national';
    }[];
  };
  lang: Locale;
  slug: string;
}

const { talk, lang, slug } = Astro.props;
const t = useTranslations(lang);
const dateFormatter = new Intl.DateTimeFormat(lang, { dateStyle: 'long' });

const earliest = (scope: 'national' | 'regional' | 'internal') =>
  talk.events.filter(e => e.scope === scope).sort((a, b) => a.date.valueOf() - b.date.valueOf())[0];
const debutEvent = earliest('national') ?? earliest('regional') ?? earliest('internal');
const thumbnail = talk.thumbnail ?? `https://picsum.photos/seed/${slug}/320/180`;
---

<a href={`/${lang}/talks/${slug}`} class="talk-card">
  <div class="talk-card__side">
    <time class="talk-card__date" datetime={debutEvent.date.toISOString()}>
      {dateFormatter.format(debutEvent.date)}
    </time>
    <div class="talk-card__thumb-wrap">
      <img
        src={thumbnail}
        alt=""
        class="talk-card__thumb"
        loading="lazy"
        decoding="async"
        width="320"
        height="180"
      />
    </div>
  </div>

  <div class="talk-card__body">
    <h2 class="talk-card__title">{talk.title}</h2>
    <p class="talk-card__event">{debutEvent.name} — {debutEvent.location}</p>
    {talk.events.length > 1 && (
      <p class="talk-card__count">{t.talks.moreEvents(talk.events.length - 1)}</p>
    )}
    <p class="talk-card__desc prose">{talk.description}</p>
    {talk.tags.length > 0 && (
      <ul class="tag-list" role="list">
        {talk.tags.map(tag => <li class="tag">{tag}</li>)}
      </ul>
    )}
  </div>
</a>

<style>
  .talk-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--size-3);
    padding-block: var(--size-4);
    border-block-end: var(--border-size-1) solid var(--border);
    text-decoration: none;
    color: inherit;

    &:last-of-type { border-block-end: none; }
    &:hover .talk-card__title { color: var(--color-brand); }
  }

  @media (width >= 560px) {
    .talk-card {
      grid-template-columns: 10rem 1fr;
      gap: var(--size-5);
    }
  }

  .talk-card__side {
    display: flex;
    flex-direction: column;
    gap: var(--size-4);
  }

  .talk-card__date {
    font-size: var(--font-size-0);
    color: var(--text-2);
  }

  .talk-card__thumb-wrap {
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-2);
    overflow: hidden;
    background: var(--surface-3);
  }

  .talk-card__thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;

    .talk-card:hover & {
      transform: scale(1.04);
    }
  }

  .talk-card__title {
    font-size: var(--font-size-2);
    margin: 0 0 var(--size-1);
    transition: color 0.15s;
  }

  .talk-card__event {
    font-size: var(--font-size-1);
    color: var(--text-2);
    margin: 0 0 0.25rem;
  }

  .talk-card__count {
    font-size: var(--font-size-0);
    color: var(--text-2);
    margin: 0 0 0.375rem;
  }

  .talk-card__desc {
    font-size: var(--font-size-1);
    color: var(--text-2);
    margin: 0 0 0.625rem;
  }
</style>
