---
import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import { useTranslations, isUpcoming, type Locale } from "../i18n/utils";
import { debutEvent } from "../content/utils";
import CardShell from "./CardShell.astro";

interface Props {
  talk: {
    title: string;
    description: string;
    thumbnail?: ImageMetadata;
    tags: string[];
    events: {
      date: Date;
      name: string;
      location: string;
      scope: "internal" | "regional" | "national";
    }[];
  };
  lang: Locale;
  slug: string;
}

const { talk, lang, slug } = Astro.props;
const t = useTranslations(lang);
const dateFormatter = new Intl.DateTimeFormat(lang, { dateStyle: "long" });

const upcoming = isUpcoming(talk.events);

const debut = debutEvent(talk.events);

const fallbackSrc = `https://picsum.photos/seed/${slug}/320/180`;
const thumbSrc = talk.thumbnail
  ? (await getImage({ src: talk.thumbnail, width: 320, height: 180 })).src
  : fallbackSrc;
---

<CardShell
  href={`/${lang}/talks/${slug}`}
  title={talk.title}
  description={talk.description}
  thumb={thumbSrc}
  tags={talk.tags}
  thumbTransitionName={`talk-thumb-${slug}`}
>
  {
    upcoming && (
      <span
        slot="thumb-overlay"
        class="upcoming-pill card__upcoming-pill"
        data-vt-name={`upcoming-${slug}`}
      >
        {t.talks.upcoming}
      </span>
    )
  }

  <p slot="meta" class="card__meta">
    <span class="card__meta-item">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5"
        ></path>
      </svg>
      <time datetime={debut.date.toISOString()}
        >{dateFormatter.format(debut.date)}</time
      >
    </span>
    <span class="card__meta-item">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M12 18.75a6 6 0 0 0 6-6v-1.5m-6 7.5a6 6 0 0 1-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 0 1-3-3V4.5a3 3 0 1 1 6 0v8.25a3 3 0 0 1-3 3Z"
        ></path>
      </svg>
      {debut.name}
    </span>
    <span class="card__meta-item">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"
        ></path>
      </svg>
      {debut.location}
    </span>
    {
      talk.events.length > 1 && (
        <span class="talk-card__count">
          {t.talks.moreEvents(talk.events.length - 1)}
        </span>
      )
    }
  </p>
</CardShell>

<style>
  .talk-card__count {
    color: var(--text-2);
    font-size: var(--font-size-0);
  }
</style>
