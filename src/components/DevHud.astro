---
import { useTranslations, type Locale } from "../i18n/utils";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<aside
  id="gol-dev-hud"
  class="dev-hud"
  transition:persist="gol-dev-hud"
  aria-hidden="true"
  data-visible="false"
  data-collapsed="false"
>
  <button
    class="dev-hud__collapse"
    type="button"
    aria-label={t.gol.hudMinimize}
    data-label-minimize={t.gol.hudMinimize}
    data-label-expand={t.gol.hudExpand}
    data-role="toggle"
  >
    <span class="dev-hud__collapse-icon" aria-hidden="true">−</span>
  </button>
  <div class="dev-hud__body">
    <div class="dev-hud__row">
      <span class="dev-hud__label">gol</span>
      <span class="dev-hud__value" data-field="engine">—</span>
    </div>
    <div class="dev-hud__row">
      <span class="dev-hud__label">fps</span>
      <span class="dev-hud__value" data-field="fps">—</span>
    </div>
    <div class="dev-hud__row">
      <span class="dev-hud__label">grid</span>
      <span class="dev-hud__value" data-field="grid">—</span>
    </div>
    <div class="dev-hud__row">
      <span class="dev-hud__label">alive</span>
      <span class="dev-hud__value" data-field="alive">—</span>
    </div>
    <div class="dev-hud__row">
      <span class="dev-hud__label">scroll</span>
      <span class="dev-hud__value" data-field="scroll">—</span>
    </div>
    <div class="dev-hud__row">
      <span class="dev-hud__label">doc</span>
      <span class="dev-hud__value" data-field="doc">—</span>
    </div>
  </div>
</aside>

<script>
  import type { GolApi } from "../gol";

  const STORAGE_KEY = "gol-hud-collapsed";

  function initHud() {
    const hud = document.getElementById("gol-dev-hud");
    if (!hud) return;

    const fields = {
      engine: hud.querySelector<HTMLElement>('[data-field="engine"]'),
      fps: hud.querySelector<HTMLElement>('[data-field="fps"]'),
      grid: hud.querySelector<HTMLElement>('[data-field="grid"]'),
      alive: hud.querySelector<HTMLElement>('[data-field="alive"]'),
      scroll: hud.querySelector<HTMLElement>('[data-field="scroll"]'),
      doc: hud.querySelector<HTMLElement>('[data-field="doc"]'),
    };
    const toggle = hud.querySelector<HTMLButtonElement>('[data-role="toggle"]');

    const getCollapsed = () => {
      try {
        return localStorage.getItem(STORAGE_KEY) === "1";
      } catch {
        return false;
      }
    };
    const setCollapsed = (collapsed: boolean) => {
      hud.setAttribute("data-collapsed", collapsed ? "true" : "false");
      if (toggle) {
        const min = toggle.dataset.labelMinimize!;
        const exp = toggle.dataset.labelExpand!;
        toggle.setAttribute("aria-label", collapsed ? exp : min);
        const icon = toggle.querySelector<HTMLElement>(
          ".dev-hud__collapse-icon",
        );
        if (icon) icon.textContent = collapsed ? "+" : "−";
      }
      try {
        localStorage.setItem(STORAGE_KEY, collapsed ? "1" : "0");
      } catch {
        // localStorage disabled; state is still applied in-memory.
      }
    };
    setCollapsed(getCollapsed());

    toggle?.addEventListener("click", () => {
      setCollapsed(hud.getAttribute("data-collapsed") !== "true");
    });

    let unsubscribe: (() => void) | null = null;
    const bindTo = (api: GolApi) => {
      if (unsubscribe) unsubscribe();
      unsubscribe = api.onStats((stats) => {
        hud.setAttribute("data-visible", api.isEnabled() ? "true" : "false");
        if (fields.engine) fields.engine.textContent = stats.engine;
        if (fields.fps) fields.fps.textContent = String(stats.fps);
        if (fields.grid)
          fields.grid.textContent = `${stats.cells.cols}×${stats.cells.rows}`;
        if (fields.alive) fields.alive.textContent = String(stats.cells.alive);
        if (fields.scroll)
          fields.scroll.textContent = `${Math.round(stats.scrollY)}px`;
        if (fields.doc) fields.doc.textContent = `${stats.docHeight}px`;
      });
    };

    const tryBind = () => {
      if (window.__gol) {
        bindTo(window.__gol);
        return true;
      }
      return false;
    };

    if (!tryBind()) {
      // Poll briefly for the controller to appear after first enable().
      const iv = window.setInterval(() => {
        if (tryBind()) window.clearInterval(iv);
      }, 200);
    }
  }

  document.addEventListener("astro:page-load", initHud);
</script>

<style>
  .dev-hud {
    position: fixed;
    z-index: 9999;
    right: 0.75rem;
    bottom: 0.75rem;
    display: none;
    flex-direction: column;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-2);
    backdrop-filter: blur(6px);
    background: color-mix(in oklch, var(--surface-2) 92%, transparent);
    box-shadow: var(--shadow-2);
    color: var(--text-2);
    font-family: var(--font-mono, ui-monospace), monospace;
    font-size: 0.75rem;
    gap: 0.125rem;
  }

  .dev-hud[data-visible="true"] {
    display: flex;
    flex-wrap: nowrap;
  }

  .dev-hud[data-collapsed="true"] {
    padding: 0.25rem;
  }

  .dev-hud__body {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .dev-hud[data-collapsed="true"] .dev-hud__body {
    display: none;
  }

  .dev-hud__row {
    display: flex;
    flex-wrap: nowrap;
    justify-content: space-between;
    gap: 1rem;
  }

  .dev-hud__label {
    color: var(--text-2);
    opacity: 0.7;
  }

  .dev-hud__value {
    color: var(--text-1);
    font-variant-numeric: tabular-nums;
  }

  .dev-hud__collapse {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    align-self: flex-end;
    justify-content: center;
    padding: 0;
    border: none;
    border-radius: var(--radius-1);
    background: transparent;
    color: var(--text-2);
    cursor: pointer;
    font-family: inherit;
    line-height: 1;
    transition:
      background var(--duration-quick-2),
      color var(--duration-quick-2);
  }

  .dev-hud__collapse-icon {
    width: 1rem;
    font-size: 0.9rem;
    font-weight: 700;
    line-height: 1;
    text-align: center;
  }

  .dev-hud__collapse:focus-visible {
    outline: 2px solid var(--color-brand);
    outline-offset: 2px;
  }

  .dev-hud[data-collapsed="true"] .dev-hud__collapse {
    align-self: center;
  }

  @media (hover: hover) {
    .dev-hud__collapse:hover {
      background: var(--surface-3);
      color: var(--text-1);
    }
  }
</style>
