---
import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import { useTranslations, type Locale } from "../i18n/utils";
import CardShell from "./CardShell.astro";
import Icon from "./Icon.astro";

interface Props {
  post: {
    title: string;
    description: string;
    pubDate: Date;
    thumbnail?: ImageMetadata;

    tags: string[];
    body?: string;
  };
  lang: Locale;
  slug: string;
}

const { post, lang, slug } = Astro.props;
const t = useTranslations(lang);
const dateFormatter = new Intl.DateTimeFormat(lang, { dateStyle: "long" });

const wordCount = post.body?.split(/\s+/).length ?? 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 300));

const thumbSrc = post.thumbnail
  ? (await getImage({ src: post.thumbnail, width: 320, height: 180 })).src
  : `https://picsum.photos/seed/${slug}/320/180`;
---

<CardShell
  href={`/${lang}/blog/${slug}`}
  title={post.title}
  description={post.description}
  thumb={thumbSrc}
  tags={post.tags}
  thumbTransitionName={`blog-thumb-${slug}`}
>
  <p slot="meta" class="card__meta">
    <span class="icon-row">
      <Icon name="calendar" />
      <time datetime={post.pubDate.toISOString()}
        >{dateFormatter.format(post.pubDate)}</time
      >
    </span>
    <span class="icon-row">
      <Icon name="clock" />
      {t.blog.readingTime(readingTime)}
    </span>
  </p>
</CardShell>
