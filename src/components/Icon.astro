  ],
} satisfies Record<string, string[]>;

export type IconName = keyof typeof ICONS;

interface Props {
  name: IconName;
}

const { name } = Astro.props;
---

<svg
  width="1em"
  height="1em"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  {ICONS[name].map((d) => <path d={d} />)}
</svg>
