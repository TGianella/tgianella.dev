---
import {
  useTranslations,
  isUpcoming,
  getDateFormatter,
  type Locale,
} from "../i18n/utils";
import Pill from "./Pill.astro";

interface Props {
  event: {
    date: Date;
    name: string;
    url?: string;
    location: string;
    scope: "internal" | "regional" | "national";
    videoId?: string;
    timestamp?: number;
    duration?: number;
  };
  lang: Locale;
}

const { event, lang } = Astro.props;
const t = useTranslations(lang);
const dateFormatter = getDateFormatter(lang);
const upcoming = isUpcoming([event]);
---

<li class="event-card">
  <div class="event-card__main">
    <time class="event-card__date" datetime={event.date.toISOString()}>
      {dateFormatter.format(event.date)}
    </time>
    <span class="event-card__name">
      {
        event.url ? (
          <a href={event.url} target="_blank" rel="noopener noreferrer">
            {event.name}&nbsp;↗
          </a>
        ) : (
          event.name
        )
      }
    </span>
    <div class="event-card__location-row">
      <span class="event-card__location">
        {event.location}{event.duration && ` · ${event.duration} min`}
      </span>
      {upcoming && <Pill variant="brand">{t.talks.upcoming}</Pill>}
      {
        event.scope === "internal" && (
          <Pill variant="neutral">{t.talks.internalEvent}</Pill>
        )
      }
    </div>
  </div>

  {
    event.videoId && (
      <a
        href={`https://www.youtube.com/watch?v=${event.videoId}${event.timestamp ? `&t=${event.timestamp}` : ""}`}
        target="_blank"
        rel="noopener noreferrer"
        class="event-card__video-btn"
        aria-label={t.talks.watchReplay}
        data-tooltip={t.talks.watchReplay}
      >
        ▶
      </a>
    )
  }
</li>

<style>
  .event-card {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    padding: var(--size-3);
    border-radius: var(--radius-2);
    background: var(--surface-2);
    box-shadow: var(--shadow-2);
    gap: var(--size-3);
  }

  .event-card__main {
    display: flex;
    flex: 1;
    flex-direction: column;
    gap: 0.25rem;
  }

  .event-card__date {
    color: var(--text-2);
    font-size: var(--font-size-0);
  }

  .event-card__location-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--size-2);
  }

  .event-card__name {
    font-size: var(--font-size-1);
    font-weight: var(--font-weight-6);
    text-wrap: balance;

    & a {
      color: inherit;
      text-decoration: none;

      @media (hover: hover) {
        &:hover {
          color: var(--color-brand);
        }
      }
    }
  }

  .event-card__location {
    color: var(--text-2);
    font-size: var(--font-size-0);
  }

  .event-card__video-btn {
    position: relative;
    display: flex;
    flex-shrink: 0;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: center;
    border: var(--border-size-1) solid var(--border);
    border-radius: var(--radius-2);
    background: var(--surface-3);
    block-size: 2.5rem;
    color: var(--color-brand);
    font-size: var(--font-size-1);
    inline-size: 2.5rem;
    text-decoration: none;
    transition: opacity var(--duration-quick-2);

    @media (hover: hover) {
      &:hover {
        opacity: 0.75;
      }
    }

    &::after {
      position: absolute;
      bottom: calc(100% + var(--size-2));
      left: 50%;
      padding: 0.2em 0.5em;
      border: var(--border-size-1) solid var(--border);
      border-radius: var(--radius-2);
      background: var(--surface-3);
      color: var(--text-2);
      content: attr(data-tooltip);
      font-size: var(--font-size-0);
      opacity: 0;
      pointer-events: none;
      transition:
        opacity var(--duration-quick-2),
        translate var(--duration-quick-2);
      translate: -50% var(--size-2);
      white-space: nowrap;
    }

    &:focus-visible::after {
      opacity: 1;
      translate: -50% 0;
    }

    @media (hover: hover) {
      &:hover::after {
        opacity: 1;
        translate: -50% 0;
      }
    }
  }
</style>
