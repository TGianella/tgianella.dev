---
interface Props {
  href: string;
  title: string;
  description: string;
  thumb: string;
  thumbAlt?: string;
  tags?: string[];
  thumbTransitionName?: string;
}

const {
  href,
  title,
  description,
  thumb,
  thumbAlt = "",
  tags = [],
  thumbTransitionName,
} = Astro.props;
---

<a href={href} class="card" data-vt-name={thumbTransitionName || undefined}>
  <div class="card__side">
    <div class="card__thumb-wrap">
      <img
        src={thumb}
        alt={thumbAlt}
        class="card__thumb"
        loading="lazy"
        decoding="async"
      />
      <slot name="thumb-overlay" />
    </div>
  </div>

  <div class="card__body">
    <slot name="meta" />
    <h2 class="card__title">{title}</h2>
    <p class="card__desc">{description}</p>
    {
      tags.length > 0 && (
        <ul class="tag-list">
          {tags.map((tag) => (
            <li class="tag">{tag}</li>
          ))}
        </ul>
      )
    }
  </div>
</a>

<style>
  .card__title {
    margin: 0 0 0.25rem;
    font-size: var(--font-size-3);
    transition: color 0.15s;
  }

  .card {
    display: grid;
    align-items: center;
    padding: var(--size-4);
    border-radius: var(--radius-2);
    border-block-end: var(--border-size-1) solid var(--border);
    color: inherit;
    gap: var(--size-5);
    grid-template-columns: minmax(auto, 16rem) 1fr;
    text-decoration: none;
    transition: background 0.15s;

    &:last-of-type {
      border-block-end: none;
    }

    &:hover,
    &:focus-visible {
      background: var(--surface-2);
      outline: 2px solid var(--color-brand);
      outline-offset: 2px;
    }

    &:hover .card__title,
    &:focus-visible .card__title {
      color: var(--color-brand);
    }
  }

  @media (width < 560px) {
    .card {
      gap: var(--size-3);
      grid-template-columns: 1fr;
    }
  }

  .card__thumb-wrap {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-2);
    aspect-ratio: 16 / 9;
    background: var(--surface-3);
    max-block-size: 9rem;
    max-inline-size: 16rem;
  }

  @media (width < 560px) {
    .card__thumb-wrap {
      max-block-size: unset;
      max-inline-size: unset;
    }
  }

  .card__thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;

    .card:hover & {
      transform: scale(1.04);
    }
  }

  .card__desc {
    display: -webkit-box;
    overflow: hidden;
    margin: 0 0 0.625rem;
    -webkit-box-orient: vertical;
    color: var(--text-2);
    font-size: var(--font-size-1);
    -webkit-line-clamp: 3;
  }

  /* ── Slotted content ─────────────────────────── */
  .card :global(.card__meta) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    margin: 0 0 0.25rem;
    color: var(--text-2);
    font-size: var(--font-size-1);
    gap: 0.2em 0.9em;
  }

  .card :global(.card__meta-item) {
    display: flex;
    align-items: center;
    gap: 0.3em;
  }

  .card :global(.card__meta-item svg) {
    width: 1em;
    height: 1em;
    flex-shrink: 0;
    opacity: 0.7;
  }

  .card :global(.card__upcoming-pill) {
    position: absolute;
    top: var(--size-2);
    left: var(--size-2);
    padding: 1px var(--size-2);
    backdrop-filter: blur(4px);
    background: color-mix(in oklch, var(--color-brand) 18%, var(--surface-1));
    font-size: var(--font-size-0);
    view-transition-class: text-transition;
  }

  @media (width < 560px) {
    .card :global(.card__upcoming-pill) {
      padding: var(--size-1) var(--size-3);
      font-size: var(--font-size-1);
    }
  }
</style>
