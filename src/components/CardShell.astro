---
interface Props {
  href: string;
  title: string;
  description: string;
  thumb: string;
  thumbAlt?: string;
  tags?: string[];
  thumbTransitionName?: string;
}

const {
  href,
  title,
  description,
  thumb,
  thumbAlt = "",
  tags = [],
  thumbTransitionName,
} = Astro.props;
---

<a href={href} class="card" data-vt-name={thumbTransitionName || undefined}>
  <div class="card__side">
    <div class="card__thumb-wrap">
      <img
        src={thumb}
        alt={thumbAlt}
        class="card__thumb"
        loading="lazy"
        decoding="async"
      />
      <slot name="thumb-overlay" />
    </div>
  </div>

  <div class="card__body">
    <slot name="meta" />
    <h2 class="card__title">{title}</h2>
    <p class="card__desc">{description}</p>
    {
      tags.length > 0 && (
        <ul class="tag-list">
          {tags.map((tag) => (
            <li class="tag">{tag}</li>
          ))}
        </ul>
      )
    }
  </div>
</a>

<style>
  .card__title {
    margin: 0 0 var(--size-1);
    font-size: var(--font-size-3);
    transition: color var(--duration-quick-2);
  }

  .card {
    display: grid;
    align-items: center;
    padding: var(--size-4);
    border-radius: var(--radius-2);
    color: inherit;
    gap: var(--size-3);
    grid-template-columns: [content-start] 1fr [content-end];
    text-decoration: none;
    transition: background var(--duration-quick-2);

    &:focus-visible {
      background: var(--surface-2);
      outline: 2px solid var(--color-brand);
      outline-offset: 2px;
    }

    &:focus-visible .card__title {
      color: var(--color-brand);
    }

    @media (hover: hover) {
      &:hover {
        background: var(--surface-2);
        box-shadow: var(--shadow-3);
        outline: var(--border-size-2) solid var(--color-brand);
      }

      &:hover .card__title {
        color: var(--color-brand);
      }
    }
  }

  @media (width >= 560px) {
    .card {
      gap: var(--size-5);
      grid-template-columns:
        [thumb-start] minmax(auto, 16rem)
        [thumb-end body-start] 1fr [body-end];
    }
  }

  .card__thumb-wrap {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-2);
    aspect-ratio: 16 / 9;
    background: var(--surface-3);
  }

  @media (width >= 560px) {
    .card__thumb-wrap {
      max-block-size: 9rem;
      max-inline-size: 16rem;
    }
  }

  .card__thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-gentle-1) ease;

    @media (hover: hover) {
      .card:hover & {
        transform: scale(1.04);
      }
    }
  }

  .card__desc {
    display: -webkit-box;
    overflow: hidden;
    margin: 0 0 var(--size-2);
    -webkit-box-orient: vertical;
    color: var(--text-2);
    font-size: var(--font-size-1);
    -webkit-line-clamp: 3;
  }

  /* ── Slotted content ─────────────────────────── */
  .card :global(.card__meta) {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    color: var(--text-2);
    font-size: var(--font-size-1);
    gap: 0.2em 0.9em;
    margin-block: 0 var(--size-1);
  }

  /* .card__meta-item icon layout is provided by the global .icon-row class */

  .card :global(.card__upcoming-pill) {
    position: absolute;
    top: var(--size-2);
    left: var(--size-2);
    padding: var(--size-1) var(--size-3);
    backdrop-filter: blur(4px);
    background: color-mix(in oklch, var(--color-brand) 18%, var(--surface-1));
    font-size: var(--font-size-1);
    view-transition-class: text-transition;
  }

  @media (width >= 560px) {
    .card :global(.card__upcoming-pill) {
      padding: 1px var(--size-2);
      font-size: var(--font-size-0);
    }
  }
</style>
