---
import { ClientRouter } from "astro:transitions";
import Nav from "../components/Nav.astro";
import SocialLinks from "../components/SocialLinks.astro";
import {
  useTranslations,
  getLocalizedPath,
  getAlternateLocale,
  type Locale,
} from "../i18n/utils";
import "../styles/global.css";

interface Props {
  lang: Locale;
  title?: string;
  description: string;
  /** Canonical path without locale prefix, e.g. "/blog/my-post" */
  canonicalPath?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  lang,
  title,
  description,
  canonicalPath = "/",
  ogImage,
  noindex,
} = Astro.props;
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;

const alternateLang = getAlternateLocale(lang);
const alternateUrl = new URL(
  getLocalizedPath(canonicalPath, alternateLang),
  Astro.site,
);
const canonicalUrl = new URL(getLocalizedPath(canonicalPath, lang), Astro.site);

const ogImageUrl = ogImage ?? new URL("/og-default.png", Astro.site).toString();
const pageTitle = title ? `${title} — ${t.seo.siteName}` : t.seo.siteName;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <!-- Primary -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />

    <!-- Alternate locale -->
    <link rel="alternate" hreflang={lang} href={canonicalUrl} />
    <link rel="alternate" hreflang={alternateLang} href={alternateUrl} />
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(getLocalizedPath(canonicalPath, "en"), Astro.site)}
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content={t.seo.siteName} />
    <meta property="og:locale" content={lang === "en" ? "en_US" : "fr_FR"} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Preconnect to image CDN -->
    <link rel="preconnect" href="https://images.tgianella.dev" />

    <!-- Fonts -->
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/Bitstream%20Charter.woff2"
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/Bitstream%20Charter%20Italic%20OSF.woff2"
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/Bitstream%20Charter%20Bold%20OSF.woff2"
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/Bitstream%20Charter%20Bold%20Italic%20OSF.woff2"
      crossorigin
    />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="16x16 32x32 48x48" />
    <link rel="icon" href="/favicon.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- RSS -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${t.seo.siteName} — Blog (${lang.toUpperCase()})`}
      href={`/${lang}/rss.xml`}
    />

    <script is:inline src="/theme.js"></script>

    <ClientRouter />
  </head>
  <body>
    <a href="#main-content" class="skip-link">{t.a11y.skipToMain}</a>
    <Nav lang={lang} currentPath={currentPath} />

    <main id="main-content">
      <slot />
    </main>

    <footer class="footer">
      <div class="footer__inner">
        <p class="footer__copy">
          &copy; {new Date().getFullYear()}
          {t.seo.siteName}. {t.footer.rights}
        </p>
        <SocialLinks lang={lang} />
      </div>
    </footer>
  </body>
</html>

<script>
  import "../scripts/view-transitions";
  import "../scripts/scroll-preservation";
</script>

<style>
  body {
    display: flex;
    flex-direction: column;
  }

  #main-content {
    flex: 1;
  }

  .footer {
    background-color: var(--surface-1);
    border-block-start: var(--border-size-1) solid var(--border);
    padding-block: var(--size-5);
  }

  .footer__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--size-3);
    margin-inline: auto;
    max-inline-size: var(--layout-width);
    padding-inline: var(--page-padding);
  }

  .footer__copy {
    margin: 0;
    color: var(--text-2);
    font-size: var(--font-size-1);
    text-wrap: balance;
  }
</style>
